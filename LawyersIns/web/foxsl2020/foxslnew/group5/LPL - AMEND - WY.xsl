<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo" xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">

	<xsl:template match="/" name="LPL-AMEND-WY">

		<fo:block>
			<xsl:call-template name="CommonHeader" />
		</fo:block>

		<fo:block text-align="center" margin-left="1.3in"
			margin-right="1.3in" font-size="12px"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			space-before="5mm" space-after="5mm" font-weight="bold">
			WYOMING AMENDATORY ENDORSEMENT
		</fo:block>
		<fo:block padding-left="5pt"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			font-size="10px" text-align="justify">

			<fo:block space-after="4mm">
				In consideration of the premium charged, it is agreed that:
			</fo:block>
			
			<fo:block space-after="4mm">


				<fo:list-block>
					<fo:list-item space-after="4mm">
						<fo:list-item-label>
							<fo:block>
								<fo:inline>1.</fo:inline>
							</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="7mm">
							<fo:block space-after="4mm">
								Section VI., General Condition C., Action Against Insurer, is amended by addition of the following:
							</fo:block>
							<fo:block>
							<fo:list-block>
							<fo:list-item>
							<fo:list-item-label>
							<fo:block font-weight="bold">
								•
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="14mm">
							<fo:block>
								Suit upon causes of action arising within Wyoming against the Insurer
								over this policy shall be brought in the county where the cause of
								action arose or in the county where the Named Insured instituting the
								action resides.
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							</fo:list-block>
							</fo:block>
						</fo:list-item-body>
					</fo:list-item>
					<fo:list-item space-after="4mm">
						<fo:list-item-label>
							<fo:block>
								<fo:inline>2.</fo:inline>
							</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="7mm">
							<fo:block space-after="4mm">
								Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
							</fo:block>
							<fo:block>
							<fo:list-block>
							<fo:list-item>
							<fo:list-item-label>
							<fo:block font-weight="bold">
								D.
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="14mm">
							<fo:block space-after="4mm" font-weight="bold">
								Cancellation, Nonrenewal and Conditional Renewal
							</fo:block>
							<fo:block>
							<fo:list-block>
							<fo:list-item space-after="4mm">
							<fo:list-item-label>
							<fo:block font-weight="bold">
								1.
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="21mm">
							<fo:block font-weight="bold" space-after="4mm">
								Cancellation
							</fo:block>
							<fo:block space-after="4mm">
							<fo:list-block>
							<fo:list-item space-after="4mm">
							<fo:list-item-label>
							<fo:block>
								(a)
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="28mm">
							<fo:block>
								The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the
								expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written notice
								to the <fo:inline font-weight="bold">Insurer</fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline> or its
								authorized agent. If the <fo:inline font-weight="bold">Named Insured</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline>
								shall return 90% of the unearned portion of the premium.
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							<fo:list-item>
							<fo:list-item-label>
							<fo:block>
								(b)
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="28mm">
							<fo:block>
								The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium
								or Deductible. This policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or
								personally delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline> and the agent, at their
								addresses last of record with the <fo:inline font-weight="bold">Insurer</fo:inline>, written notice of
								cancellation at least 10 days before the effective date of
								cancellation. Such notice shall state the precise reason for
								cancellation. If mailed, notice shall be deemed given when deposited in
								the United States mail, postage prepaid. Proof of mailing shall be
								sufficient proof of notice and the effective date of cancellation
								stated in such notice shall become the expiration date of the <fo:inline font-weight="bold">Policy
								Period</fo:inline>. If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall, prior to
								cancellation, refund the <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of
								the premium. Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline>
								shall not be a condition precedent to the effectiveness of
								cancellation, but such payment shall be made as soon as practicable.
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							</fo:list-block>
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							<fo:list-item space-after="4mm">
							<fo:list-item-label>
							<fo:block font-weight="bold">
								2.
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="21mm">
							<fo:block space-after="4mm" font-weight="bold">
								Nonrenewal
							</fo:block>
							<fo:block space-after="4mm">
								This policy may be nonrenewed by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or personally
								delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline> and the agent, at their addresses last
								of record with the <fo:inline font-weight="bold">Insurer</fo:inline>, written notice of nonrenewal at least 45
								days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>. Such notice
								shall state the precise reason for nonrenewal. If mailed, notice shall
								be deemed given when deposited in the United States mail, postage
								prepaid. Proof of mailing shall be sufficient proof of notice.
							</fo:block>
							<fo:block start-indent="14mm">
								Subject to the provisions of subsection 3. below, a nonrenewal or
								cancellation notice shall not be required if a policy is transferred
								from the <fo:inline font-weight="bold">Insurer</fo:inline> to an affiliated insurer under common management and
								control: (a) as a result of a merger, acquisition or company
								restructuring; or (b) if the transfer results in the same or broader
								coverage.
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							<fo:list-item space-after="4mm">
							<fo:list-item-label>
							<fo:block font-weight="bold">
								3.
							</fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="21mm">
							<fo:block space-after="4mm" font-weight="bold">
								Conditional Renewal
							</fo:block>
							<fo:block>
								If the <fo:inline font-weight="bold">Insurer</fo:inline> intends to renew this policy, but on less favorable
								terms or at higher rates, the <fo:inline font-weight="bold">Insurer</fo:inline> shall furnish to the <fo:inline font-weight="bold">Named
								Insured</fo:inline> and the agent of record, if any, renewal terms and a statement
								of the amount of premium due for the renewal policy. The renewal terms
								and statement of premium due shall be personally 
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							</fo:list-block>
							</fo:block>
							</fo:list-item-body>
							</fo:list-item>
							</fo:list-block>
							</fo:block>
						</fo:list-item-body>
					</fo:list-item>
					</fo:list-block>
			</fo:block>
			<fo:block margin-top="2cm"/>
           <fo:block  font-size="9px" color="grey" text-align="left">LPL-AMEND-WY (04/17)&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Page 1 of 2</fo:block>
		</fo:block>
		<fo:block break-after="page" />
		
		<fo:block padding-left="5pt"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			font-size="10px" text-align="justify">
			
		<fo:block start-indent="21mm" space-after="4mm">
			delivered or mailed to the <fo:inline font-weight="bold">Named Insured</fo:inline> and the agent at their
			addresses last of record with the <fo:inline font-weight="bold">Insurer</fo:inline> not less than 45 days prior
			to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>. If mailed, notice shall be
			deemed given when deposited in the United States mail, postage prepaid.
			Proof of mailing shall be sufficient proof of notice.
		</fo:block>
		<fo:block start-indent="21mm" space-after="4mm">
			If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to furnish the renewal terms and statement of
			premium due in the manner required by this subsection, the <fo:inline font-weight="bold">Named
			Insured</fo:inline> may elect to cancel the renewal policy within the 45-day period
			following receipt of the renewal terms and statement of premium due.
			Earned premium for any period of coverage shall be calculated pro rata
			based upon the premium applicable to the original policy and not the
			premium applicable to the renewal policy.
		</fo:block>
		<fo:list-block space-after="4mm">
		<fo:list-item>
		<fo:list-item-label>
		<fo:block>
			3.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="7mm">
		<fo:block space-after="4mm">
			Section VI., General Condition M., <fo:inline font-weight="bold">Named Insured</fo:inline> Sole Agent, paragraph 2., is deleted and replaced with the following:
		</fo:block>
		<fo:block>
		<fo:list-block>
		<fo:list-item>
		<fo:list-item-label>
		<fo:block>
			2.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="14mm">
		<fo:block>
			for the completing of any applications and the making of any statements and representations for the policy; and
		</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		</fo:list-block>
		</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		</fo:list-block>
		<fo:block space-after="8mm">
			It is further agreed that, notwithstanding anything in this policy to
			the contrary, the tender of the Limit of Liability before judgment or
			settlement does not relieve the <fo:inline font-weight="bold">Insurer</fo:inline> of its duty to defend.
		</fo:block>
		<fo:block>
			All other terms, conditions and limitations of the policy remain unaltered.
		</fo:block>
		<fo:block margin-top="18.5cm"/>
           <fo:block  font-size="9px" color="grey" text-align="left">LPL-AMEND-WY (04/17)&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Page 2 of 2</fo:block>
		</fo:block>
		<fo:block page-break-before="auto"></fo:block>
	</xsl:template>
</xsl:stylesheet>
