<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo" xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">

	<xsl:template match="/" name="LPL-AMEND-CT">

		<fo:block>
			<xsl:call-template name="CommonHeader" />
		</fo:block>

		<fo:block text-align="center" margin-left="1.3in"
			margin-right="1.3in" font-size="12px"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			space-before="5mm" space-after="5mm" font-weight="bold">
			CONNECTICUT AMENDATORY ENDORSEMENT
		</fo:block>
		<fo:block padding-left="5pt"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			font-size="10px" text-align="justify">

			<fo:block space-after="4mm">
				In consideration of the premium charged, it is agreed that,
				notwithstanding anything in this policy to the contrary, a <fo:inline font-weight="bold">Claim</fo:inline> shall
				be deemed first made when the <fo:inline font-weight="bold">Insurer</fo:inline> receives written notice of a
				<fo:inline font-weight="bold">Claim</fo:inline> from the <fo:inline font-weight="bold">Insured</fo:inline> or a third party.
			</fo:block>
			<fo:block space-after="4mm">
				It is further agreed that:
			</fo:block>

			<fo:block space-after="4mm">


				<fo:list-block>
					<fo:list-item space-after="4mm">
						<fo:list-item-label>
							<fo:block>
								<fo:inline>1.</fo:inline>
							</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="7mm">
							<fo:block space-after="4mm">
								Section III., Extension of Coverage B., Spousal and Domestic Partner
								Extension, is amended by deleting the phrase “lawful spouse or lawful
								domestic partner” and replacing it with “lawful spouse, lawful domestic
								partner or party to a civil union recognized under Connecticut law”.
							</fo:block>
						</fo:list-item-body>
					</fo:list-item>
					<fo:list-item space-after="4mm">
					<fo:list-item-label>
						<fo:block>2.</fo:block>
					</fo:list-item-label>
					<fo:list-item-body start-indent="7mm">
						<fo:block space-after="4mm">
							Section III., Extension of Coverage D., Extended Reporting Period
							Extensions, subsections 1., Automatic Extended Reporting Period, and
							2., Optional Extended Reporting Period, are deleted and replaced with
							the following:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item space-after="4mm">
						<fo:list-item-label>
						<fo:block font-weight="bold">
							1.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="14mm">
						<fo:block font-weight="bold" space-after="4mm">
							Automatic Extended Reporting Period
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item space-after="4mm">
						<fo:list-item-label>
						<fo:block>
							(a)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block space-after="4mm">
							Upon <fo:inline font-weight="bold">Termination of Coverage</fo:inline>, the <fo:inline font-weight="bold">Named Insured</fo:inline> shall be provided
							with an automatic and non-cancelable period of 60 days, commencing on
							the date of such <fo:inline font-weight="bold">Termination of Coverage</fo:inline>, to report <fo:inline font-weight="bold">Claims</fo:inline> to the
							<fo:inline font-weight="bold">Insurer</fo:inline> pursuant to Section VI., General Condition A.1, Notice of <fo:inline font-weight="bold">Claim</fo:inline>. Coverage under this extension of time to
							report a <fo:inline font-weight="bold">Claim</fo:inline> (referred to below as the Automatic Extended Reporting
							Period) shall apply solely to negligent acts, errors or omissions in
							rendering <fo:inline font-weight="bold">Professional Services</fo:inline>:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(1)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							committed or attempted prior to the effective date of <fo:inline font-weight="bold">Termination of Coverage</fo:inline>; and
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(2)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							which are not otherwise excluded by any terms, conditions or exclusions of this policy.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(b)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							This Automatic Extended Reporting Period shall not be applicable,
							however, in the event the <fo:inline font-weight="bold">Named Insured</fo:inline> has obtained another policy of
							Lawyers Professional Liability insurance with an inception date as of
							the termination date of this policy.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block font-weight="bold">
							2.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="14mm">
						<fo:block font-weight="bold" space-after="4mm">
							Optional Extended Reporting Period
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item space-after="4mm">
						<fo:list-item-label>
						<fo:block>
							(a)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block space-after="4mm">
							Upon
							<fo:inline font-weight="bold">Termination of Coverage</fo:inline>, the
							<fo:inline font-weight="bold">Named Insured</fo:inline> 
							shall have the right, upon payment of the additional premium shown in
							one of the options below for the length of time shown, to report
							<fo:inline font-weight="bold">Claims</fo:inline> 
							pursuant to Section VI., General Condition A.1, Notice of 
							<fo:inline font-weight="bold">Claim</fo:inline> 
							. The Optional Extended Reporting Periods
							are:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(1)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							12 months for a premium charge of 100% of the annual policy premium;
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(2)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							36 months for a premium charge of 185% of the annual policy premium;
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(3)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							60 months for a premium charge of 225% of the annual policy premium;
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(4)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							72 months for a premium charge of 250% of the annual policy premium;
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(5)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							An unlimited period for a premium charge of 300% of the annual policy premium.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(b)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							The premium charged for an Optional Extended Reporting Period shall
							be based upon the rates for such coverage in effect on the later of the
							date the policy was issued or last renewed, and the <fo:inline font-weight="bold">Insurer</fo:inline> shall not
							charge a different premium for such coverage due to any change in its
							rates, rating plans or rating rules subsequent to issuance or last
							renewal of the policy.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
			</fo:block>
			<fo:block margin-top="3cm"/>
           <fo:block  font-size="9px" color="grey" text-align="left">LPL-AMEND-CT (01/20)&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
               &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Page 1 of 4</fo:block>
		</fo:block>
		<fo:block break-after="page" />
		<fo:block padding-left="5pt"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			font-size="10px" text-align="justify">
						<fo:list-block>
						<fo:list-item space-after="4mm">
						<fo:list-item-label start-indent="14mm">
						<fo:block>
							(c)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							Where premium is due to the <fo:inline font-weight="bold">Insurer</fo:inline> for the policy, any monies
							received by the <fo:inline font-weight="bold">Insurer</fo:inline> from the <fo:inline font-weight="bold">Named Insured</fo:inline> for the Optional
							Extended Reporting Period shall be first applied to such premium owing
							for the policy. The Optional Extended Reporting Period will not take
							effect until the premium owing for the policy is paid in full and
							unless the premium for the Optional Extended Reporting Period is paid
							promptly when due.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item space-after="4mm">
						<fo:list-item-label start-indent="14mm">
						<fo:block>
							(d)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							The <fo:inline font-weight="bold">Insurer</fo:inline> shall advise the <fo:inline font-weight="bold">Named Insured</fo:inline> in writing of the
							Automatic Extended Reporting Period and the availability of, the
							premium for, and the importance of purchasing an Optional Extended
							Reporting Period. This advice shall be sent no earlier than the date of
							notification of <fo:inline font-weight="bold">Termination of Coverage</fo:inline> nor later than 15 days after
							<fo:inline font-weight="bold">Termination of Coverage</fo:inline>. The <fo:inline font-weight="bold">Named Insured</fo:inline> shall have 60 days from the
							effective date of <fo:inline font-weight="bold">Termination of Coverage</fo:inline> to submit written acceptance
							of an Optional Extended Reporting Period.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item space-after="4mm">
						<fo:list-item-label start-indent="14mm">
						<fo:block>
							(e)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block space-after="4mm">
							Coverage under such extension of time to report a <fo:inline font-weight="bold">Claim</fo:inline> (referred
							to below as the Optional Extended Reporting Period) shall apply:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(1)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							solely to negligent acts, errors or omissions in rendering
							<fo:inline font-weight="bold">Professional Services</fo:inline> committed or attempted prior to the effective
							date of <fo:inline font-weight="bold">Termination of Coverage</fo:inline>; and
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(2)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							only in regard to that coverage terminated, and shall be made
							available on the same terms, conditions and exclusions as those
							specified in the policy.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item space-after="4mm">
						<fo:list-item-label start-indent="14mm">
						<fo:block>
							(f)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block space-after="4mm">
							If the Optional Extended Reporting Period requested by the <fo:inline font-weight="bold">Named Insured</fo:inline> is issued by the <fo:inline font-weight="bold">Insurer</fo:inline>:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(1)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							the additional premium shall be fully earned by the <fo:inline font-weight="bold">Insurer</fo:inline>; and
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(2)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							the Optional Extended Reporting Period cannot be cancelled by the <fo:inline font-weight="bold">Insureds</fo:inline> or the <fo:inline font-weight="bold">Insurer</fo:inline>.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item space-after="4mm">
						<fo:list-item-label start-indent="14mm">
						<fo:block>
							(g)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							When the Optional Extended Reporting Period applies, it replaces the Automatic Extended Reporting Period.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item space-after="4mm">
						<fo:list-item-label>
						<fo:block>
							3.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="7mm">
						<fo:block space-after="4mm">
							Section III., Extension of Coverage D., Extended Reporting Period
							Extensions, subsection 4., Conditions for Extended Reporting Periods,
							is deleted and replaced with the following:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block font-weight="bold">
							4.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="14mm">
						<fo:block font-weight="bold" space-after="4mm">
						 	Conditions for Extended Reporting Periods
						</fo:block>
						<fo:block>
							As a condition precedent to the right to elect an Extended Reporting Period:
						</fo:block>
						<fo:block space-after="4mm">
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(a)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							all <fo:inline font-weight="bold">Insureds</fo:inline> must be in compliance with the terms and conditions of the policy;
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(b)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							the <fo:inline font-weight="bold">Named Insured’s</fo:inline> right to practice law has not been revoked,
							suspended or surrendered at the request of any regulatory authority for
							reasons other than death, disability or retirement; and
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(c)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							the <fo:inline font-weight="bold">Named Insured</fo:inline> provides the <fo:inline font-weight="bold">Insurer</fo:inline> with written notice of its
							selection and pays the premium charge, and any other monies due and
							owing the <fo:inline font-weight="bold">Insurer</fo:inline>, if applicable, for the selected Extended Reporting
							Period in full within 60 days of:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(1)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							<fo:inline font-weight="bold">Termination of Coverage</fo:inline> for the Optional Extended Reporting Period; and 
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(2)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline> for the Non-Practicing Extended Reporting Period. 
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						<fo:block>
							This right to elect an Extended Reporting Period shall lapse unless the
							provisions of (a) through (c) in the preceding paragraph are fully met.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							4.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="7mm">
						<fo:block space-after="4mm">
							Section IV., Definitions, is amended as follows:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item space-after="4mm">
						<fo:list-item-label>
						<fo:block>
							a.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="14mm">
						<fo:block space-after="4mm">
							Definition H., <fo:inline font-weight="bold">Immediate Family Member</fo:inline>, paragraph 6., is deleted and replaced with the following:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							6.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block>
							past or present spouse or party to a civil union recognized under Connecticut law,
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							b.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="14mm">
						<fo:block space-after="4mm">
							Definition P., <fo:inline font-weight="bold">Prior Acts Date</fo:inline>, is amended by addition of the following:
						</fo:block>
						<fo:block>
							Once the <fo:inline font-weight="bold">Prior Acts Date</fo:inline> is established with the <fo:inline font-weight="bold">Named Insured</fo:inline>, it may
							be advanced only with the written consent of the <fo:inline font-weight="bold">Named Insured</fo:inline>. Prior
							to the advancement of the <fo:inline font-weight="bold">Prior Acts Date</fo:inline> by the <fo:inline font-weight="bold">Insurer</fo:inline>, the <fo:inline font-weight="bold">Insurer</fo:inline>
							must obtain the written acknowledgement of the <fo:inline font-weight="bold">Named Insured</fo:inline> that the
							<fo:inline font-weight="bold">Named Insured</fo:inline> has been advised of the right to purchase the Optional
							Extended Reporting Period.
						</fo:block>
