<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
	
<xsl:template match="/" name="LPL-AMEND-PA">
          <fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		  </fo:block>

          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="5mm" space-after="5mm" font-weight="bold">

            PENNSYLVANIA AMENDATORY ENDORSEMENT

          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>
              
              <fo:list-item space-after="3mm">
              <fo:list-item-label>
              <fo:block>1.</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="7mm">Section III., Extension of Coverage D., Extended Reporting Period Extensions, is amended as follows:</fo:block>
              </fo:list-item-body>
              
              </fo:list-item>
              
               <fo:list-item  space-after="3mm">
              <fo:list-item-label>
              <fo:block start-indent="7mm">a.</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="14mm">Subsection 1., Automatic Extended Reporting Period, is amended by deletion of the phrase “other than for cancellation for nonpayment of premium or for nonpayment of Deductible due hereunder”.</fo:block>
              </fo:list-item-body>
              </fo:list-item>
              
              <fo:list-item  space-after="3mm">
              <fo:list-item-label>
              <fo:block start-indent="7mm">b.</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="14mm">Subsection 2., Optional Extended Reporting Period, is amended by deletion of the phrase “other than for nonpayment of premium or for the nonpayment of Deductible due hereunder”.</fo:block>
              </fo:list-item-body>
              </fo:list-item>
              
              <fo:list-item  space-after="3mm">
              <fo:list-item-label>
              <fo:block start-indent="7mm">c.</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="14mm">Subsection 3., Non-Practicing Extended Reporting Period, subsection (c), Non-Practicing Extended Reporting Period Limits of Liability, is deleted and replaced with the following:</fo:block>
              </fo:list-item-body>
              </fo:list-item>
              
              
              <fo:list-item  space-after="3mm">
              <fo:list-item-label>
              <fo:block start-indent="14mm" font-weight="bold">(c)</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="21mm" space-after="3mm" font-weight="bold">Non-Practicing Extended Reporting Period Limits of Liability</fo:block>
              
              <fo:block start-indent="21mm">The <fo:inline font-weight="bold">Insurer’s</fo:inline> Limit of Liability for all <fo:inline font-weight="bold">Claims</fo:inline> first made against an <fo:inline font-weight="bold">Insured</fo:inline> during any Non-Practicing Extended Reporting Period will be part of, and not in addition to, the Limit of Liability shown in Item 3. of the Declarations, regardless of the number of Non-Practicing Extended Reporting Periods purchased.</fo:block>
              
              </fo:list-item-body>
              </fo:list-item>
              
                <fo:list-item  space-after="3mm">
              <fo:list-item-label>
              <fo:block start-indent="7mm">d.</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="14mm">Subsection 4., Conditions for Extended Reporting Periods, is deleted and replaced with the following:</fo:block>
              </fo:list-item-body>
              </fo:list-item>
              
              
               <fo:list-item >
              <fo:list-item-label>
              <fo:block font-weight="bold" start-indent="14mm">4.</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block font-weight="bold" space-after="3mm" start-indent="21mm">Conditions for Extended Reporting Periods</fo:block>
              <fo:block start-indent="21mm">As a condition precedent to the right to elect an Extended Reporting Period:</fo:block>
              </fo:list-item-body>
              </fo:list-item>
              
              <fo:list-item  >
              <fo:list-item-label>
              <fo:block start-indent="21mm">(a)</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="28mm">all Insureds must be in compliance with the terms and conditions of the policy;</fo:block>
               </fo:list-item-body>
              </fo:list-item>
              
               <fo:list-item >
              <fo:list-item-label>
              <fo:block start-indent="21mm">(b)</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="28mm">the Named Insured’s right to practice law has not been revoked, suspended or surrendered at the request of any regulatory authority for reasons other than death, disability or retirement; and</fo:block>
               </fo:list-item-body>
              </fo:list-item>
              
              
               <fo:list-item  space-after="3mm">
              <fo:list-item-label>
              <fo:block start-indent="21mm">(c)</fo:block>
              </fo:list-item-label>
              <fo:list-item-body>
              <fo:block start-indent="28mm">the Named Insured provides the Insurer with written notice of its selection and pays the premium charge, and any other monies due and owing the Insurer, if applicable, for the selected Extended Reporting Period in full within 60 days of the expiration date of the Policy Period.</fo:block>
               <fo:block start-indent="28mm">This right to elect an Extended Reporting Period shall lapse unless the provisions of (a) through (c) in the preceding paragraph are fully met.</fo:block>
               </fo:list-item-body>
              </fo:list-item>
              

                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>2.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block space-after="3mm" start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
                      </fo:block>
                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline font-weight="bold">D.</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                <fo:inline font-weight="bold"> Cancellation, Nonrenewal, Loss Information and Premium Increase</fo:inline>
                              </fo:block>
                              <fo:block>
                                <fo:list-block>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">1.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Cancellation</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm" space-after="3mm">
                                              The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the expiration date of the
                                              <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written notice to the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline> or its authorized
                                              agent.  If the <fo:inline font-weight="bold">Named Insured</fo:inline> cancels this policy, the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> shall return 90% of the unearned portion of the premium within
                                              30 days after the effective date of cancellation.
                                              
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(b)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm" space-after="3mm">
                                              <fo:block>
                                                The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium or Deductible.  This
                                                policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or delivering to the <fo:inline font-weight="bold">
                                                  Named Insured
                                                </fo:inline>, at the address shown in Item 1. of the Declarations, written notice of cancellation at least 15 days
                                                before the effective date of cancellation.  Such notice shall state the specific reasons for cancellation.  
                                                If mailed, the notice shall be forwarded by registered or first class mail.  The mailing of such notice shall be sufficient
                                                proof of notice and the effective date of cancellation stated in such notice shall become the expiration date of the
                                                <fo:inline font-weight="bold">Policy Period</fo:inline>.  If the <fo:inline font-weight="bold">Insurer</fo:inline>
                                                cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall credit the <fo:inline font-weight="bold">
                                                  Named Insured</fo:inline> the pro rata unearned portion of the premium.  Payment or tender of any unearned premium by the 
                                                  <fo:inline font-weight="bold">Insurer</fo:inline> shall not be a condition precedent to the effectiveness of cancellation,
                                                  but such payment shall be made within 10 business days after the effective date of cancellation.
                                              </fo:block>
                                               </fo:block>
                                             
                                          <!--   <fo:block  font-size="10px" color="grey" text-align="left">LPL-AMEND-PA (01/20) 
						                   <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 1 of 2</fo:block>
						                   </fo:block> -->
						                   
						                   
						                   
						                    <xsl:if test="response/policy_freeform_05/data/CompanyKey= 1">
								             <fo:block  font-size="10px" color="grey" text-align="left">LPL-AMEND-PA (01/20)
								               <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 1 of 2</fo:block>
								               </fo:block>     
								               </xsl:if>
								                 <xsl:if test="response/policy_freeform_05/data/CompanyKey= 3">
								                <fo:block  font-size="10px" color="grey" text-align="left">ISMIE ALA-04-F033 (09/01/2021)
								               <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 1 of 2</fo:block>
								               </fo:block>     
								                 </xsl:if>           
                                           
                                            
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">2.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Nonrenewal</fo:inline>
                                      </fo:block>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        This policy may be nonrenewed by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or delivering to the <fo:inline font-weight="bold">
                                          Named Insured
                                        </fo:inline>, at the address shown in Item 1. of the Declarations, written notice of nonrenewal at least 60 days prior to the expiration date of the 
                                        <fo:inline font-weight="bold">Policy Period</fo:inline>.  
                                        Such notice shall state the specific reasons for nonrenewal.  If mailed, the notice shall be forwarded by registered or first class mail.
                                        The mailing of such notice shall be sufficient proof of notice.  Until the <fo:inline font-weight="bold">Insurer</fo:inline> issues a
                                        nonrenewal notice that complies with the provisions of this subsection, coverage will remain in effect.  However, if the
                                        <fo:inline font-weight="bold">Named Insured</fo:inline> obtains replacement coverage, the <fo:inline font-weight="bold">Insurer’s</fo:inline>
                                        obligation to continue coverage ceases.
                                      </fo:block>
                                      
                                      <fo:block margin-top="3mm"></fo:block>

                                    </fo:list-item-body>
                                  </fo:list-item>

                                  <fo:list-item space-after="3mm">
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">3.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Loss Information</fo:inline>
                                      </fo:block>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        A notice of cancellation or nonrenewal shall state that, at the <fo:inline font-weight="bold">Named Insured’s</fo:inline> request, the
                                        <fo:inline font-weight="bold">Insurer</fo:inline> shall provide loss information to the <fo:inline font-weight="bold">Named Insured
                                        </fo:inline>for at least three years or the period of time during which the <fo:inline font-weight="bold">Insurer</fo:inline>
                                        has provided coverage to the <fo:inline font-weight="bold">Named Insured</fo:inline>, whichever is less.  Loss information shall 
                                        consist of the following:
                                      </fo:block>
                                      <fo:block space-after="2mm">
                                        <fo:list-block>
                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(a)</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                information on closed <fo:inline font-weight="bold">Claims</fo:inline>, including date and description of occurrence, and amount of payments, if any;
                                              </fo:block>
                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(b)</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                information on open <fo:inline font-weight="bold">Claims</fo:inline>, including date and description of occurrence, amount of payment, if any, and amount of reserves, if any; and
                                              </fo:block>
                                              <fo:block break-after="page"/>
                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(c)</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                information on notices of occurrence, including date and description of occurrence and amount of reserves, if any.  The <fo:inline font-weight="bold">
                                                  Named Insured’s</fo:inline> written request for loss information must be made within 10 days of its receipt of the cancellation
                                                  or nonrenewal notice.  The <fo:inline font-weight="bold">Insurer</fo:inline> shall have 30 days from the date of the 
                                                  <fo:inline font-weight="bold">Named Insured’s</fo:inline> written request to provide the requested information.
                                              </fo:block>
                                              
                                            </fo:list-item-body>
                                          </fo:list-item>
                                          
                                        </fo:list-block>
                                      </fo:block>
                                    </fo:list-item-body>
                                  </fo:list-item>

                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">4.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="2mm">
                                        <fo:inline font-weight="bold">Premium Increase</fo:inline>
                                      </fo:block>
                                      <fo:block start-indent="21mm" space-after="2mm">
                                        The <fo:inline font-weight="bold">Insurer</fo:inline> or its authorized agent shall provide the <fo:inline font-weight="bold">Named Insured</fo:inline>
                                        advance notice of any increase in renewal premium at least 30 days prior to the expiration of the <fo:inline font-weight="bold">
                                        Policy Period</fo:inline>.  The <fo:inline font-weight="bold">Insurer</fo:inline> is responsible for documenting that advance notice 
                                        was provided to the <fo:inline font-weight="bold">Named Insured</fo:inline>.  The <fo:inline font-weight="bold">Insurer</fo:inline>
                                        may satisfy this requirement by doing one of the following:
                                      </fo:block>
                                    
                                      <fo:block space-after="2mm">
                                        
                                        <fo:list-block>
                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(a)</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                maintaining a copy of the advance written notice provided to the <fo:inline font-weight="bold">Named Insured</fo:inline>;
                                              </fo:block>
                                              
                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(b)</fo:inline>
                                              </fo:block>
                                              
          
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                documenting its file to reflect the date and time advance notice was provided to the <fo:inline font-weight="bold">Named Insured</fo:inline>;
                                              </fo:block>
                                              
                                            </fo:list-item-body>
                                          </fo:list-item>
                                          
                                          <fo:list-item>
                                            <fo:list-item-label>
                                                                                <fo:block start-indent="21mm">
                                                <fo:inline>(c)</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                providing documentation from its agent reflecting compliance with either paragraph (a) or (b); or
                                              </fo:block>
                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(d)</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>
                                              <fo:block start-indent="28mm">
                                                providing other documentation such as renewal offers or other methods which are accepted and common within the industry as would reasonably demonstrate compliance.
                                              </fo:block>
                                            </fo:list-item-body>
                                          </fo:list-item>
                                          
                                        </fo:list-block>
                                        
                                      </fo:block>

                                      
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  
                                </fo:list-block>
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                        </fo:list-block>
                      </fo:block>

                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
              </fo:list-block>

            </fo:block>

            <fo:block>
              All other terms, conditions and limitations of the policy remain unaltered.
            </fo:block>

          </fo:block>
          
          <fo:block margin-top="11cm"/>
            <xsl:if test="response/policy_freeform_05/data/CompanyKey= 1">
             <fo:block  font-size="10px" color="grey" text-align="left">LPL-AMEND-PA (01/20)
               <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 2 of 2</fo:block>
               </fo:block>     
               </xsl:if>
                 <xsl:if test="response/policy_freeform_05/data/CompanyKey= 3">
                <fo:block  font-size="10px" color="grey" text-align="left">ISMIE ALA-04-F033 (09/01/2021)
               <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 2 of 2</fo:block>
               </fo:block>     
                 </xsl:if>                          
          
  </xsl:template>
  
</xsl:stylesheet>
