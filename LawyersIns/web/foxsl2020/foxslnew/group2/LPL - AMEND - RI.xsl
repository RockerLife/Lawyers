<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
  
  <xsl:template match="/" name="LPL-AMEND-RI">
          <fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		  </fo:block>

          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="5mm" space-after="5mm" font-weight="bold">

            RHODE ISLAND AMENDATORY ENDORSEMENT

          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>
                <fo:list-item space-after="3mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                    Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
                    </fo:block>

                    <fo:block>

                      <fo:list-block>
                        <fo:list-item>
                          <fo:list-item-label>
                            <fo:block start-indent="7mm">
                              <fo:inline font-weight="bold">D.</fo:inline>
                            </fo:block>
                          </fo:list-item-label>
                          <fo:list-item-body start-indent="14mm">

                            <fo:block space-after="3mm">
                              <fo:inline font-weight="bold">
                                Cancellation, Nonrenewal and Conditional Renewal
                              </fo:inline>
                            </fo:block>
                            <fo:block>
                              <fo:list-block>

                                <fo:list-item>
                                  <fo:list-item-label start-indent="14mm">
                                    <fo:block>
                                      <fo:inline font-weight="bold">1.</fo:inline>
                                    </fo:block>
                                  </fo:list-item-label>
                                  <fo:list-item-body start-indent="21mm">
                                    <fo:block space-after="3mm">
                                      <fo:inline font-weight="bold">Cancellation</fo:inline>
                                    </fo:block>

                                    <fo:block>

                                      <fo:list-block>

                                        <fo:list-item space-after="3mm">
                                          <fo:list-item-label start-indent="21mm">
                                            <fo:block>
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body start-indent="28mm">
                                            <fo:block>
                                              The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the expiration date of the
                                              <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written notice to the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline> or its authorized agent.  If the <fo:inline font-weight="bold">
                                                Named Insured
                                              </fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall return 90% of the unearned portion of the premium. However, if this policy is cancelled at the request of a premium finance company, it must be computed on a pro rata basis.

                                            </fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item space-after="3mm">
                                          <fo:list-item-label start-indent="21mm">
                                            <fo:block>
                                              <fo:inline>(b)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body start-indent="28mm">
                                            <fo:block>
                                              The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium or Deductible.  This policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by giving,
                                               mailing or delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline> at the mailing address shown on the policy and, if applicable,
                                                to the insurance producer of record, written notice of cancellation at least 10 days before the effective date of cancellation.
                                                  The <fo:inline font-weight="bold">Insurer</fo:inline> shall provide the <fo:inline font-weight="bold">Named Insured</fo:inline> with a written statement setting forth the reason(s) for the cancellation where the 
                                                  <fo:inline font-weight="bold">Named Insured</fo:inline> requests such a statement in writing.  Proof of mailing shall be sufficient proof of notice and the effective date of 
                                                  cancellation stated in such notice shall become the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall credit the <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of the premium.
                                                    Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline> shall not be a condition precedent to the effectiveness of cancellation, 
                                                    but such payment shall be made as soon as practicable.
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>

                                    </fo:block>
                                  </fo:list-item-body>
                                </fo:list-item>

                                <fo:list-item>
                                  <fo:list-item-label start-indent="14mm">
                                    <fo:block>
                                      <fo:inline font-weight="bold">2.</fo:inline>
                                    </fo:block>
                                  </fo:list-item-label>
                                  <fo:list-item-body start-indent="21mm">
                                    <fo:block space-after="4mm">
                                      <fo:inline font-weight="bold">Nonrenewal</fo:inline>
                                    </fo:block>

                                    <fo:block space-after="3mm">
                                   This policy may be nonrenewed by the <fo:inline font-weight="bold">Insurer</fo:inline> by giving, mailing or delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline> at the address shown on the policy and, if applicable, to the insurance producer of record, written notice of nonrenewal at least 60 days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  Proof of mailing shall be sufficient proof of notice.
                                    </fo:block>
                                    <fo:block space-after="3mm">
                                      If the notice is given, mailed or delivered less than 60 days before the expiration, coverage shall remain in effect until 60 days after notice is given, mailed or delivered.  Earned premium for any period of coverage that extends beyond the expiration date shall be considered pro-rata based upon the previous year’s rate.  For purposes of this subsection, the transfer of the <fo:inline font-weight="bold">Named Insured</fo:inline> between companies within the same insurance group is not a refusal to renew.  In addition, changes in the Deductible, changes in premium, changes in the amount of insurance, or reduction in the Limits of Liability or coverage shall not be deemed to be refusals to renew.</fo:block>
                                    
                                    <fo:block >Notice of nonrenewal shall not be required where: (1) the Insurer or a company within the same insurance group has offered to issue a renewal policy; or (2) the <fo:inline font-weight="bold">Named Insured</fo:inline> has obtained replacement coverage or has agreed in writing to obtain replacement coverage.</fo:block>
                                  <fo:block margin-top="3mm"/>
                                  </fo:list-item-body>
                                </fo:list-item>

                                <fo:list-item>
                                  <fo:list-item-label start-indent="14mm">
                                    <fo:block>
                                      <fo:inline font-weight="bold">3.</fo:inline>
                                    </fo:block>
                                  </fo:list-item-label>
                                  <fo:list-item-body start-indent="21mm">
                                    <fo:block >
                                      <fo:inline font-weight="bold">Conditional Renewal</fo:inline>
                                    </fo:block>
                                      <fo:block margin-top="3mm"/>
                                    <fo:block space-after="3mm">
                                        The <fo:inline font-weight="bold">Insurer</fo:inline> shall provide to the <fo:inline font-weight="bold">Named Insured</fo:inline> at the mailing address shown on the policy and, if applicable, to the insurance producer of record, written notice of any premium increase in excess of 10% and shall also provide the exact renewal premium, at least 60 days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline> unless the premium increase is the result of an increase in exposure at the request of the Named <fo:inline font-weight="bold">Insured</fo:inline>.  Not less than 60 days written notice, as provided herein, shall be required for any coverage elimination, reduction, diminution or increased Deductible not at the request of the <fo:inline font-weight="bold">Named Insured</fo:inline> and in this case the notice shall itemize and describe the coverage changes and shall be separate from the renewal policy.  Proof of mailing shall be sufficient proof of notice.
                                    </fo:block>
                                 
           </fo:list-item-body>
                                </fo:list-item>

                              </fo:list-block>
                            </fo:block>
                          </fo:list-item-body>
                        </fo:list-item>
                      </fo:list-block>
                    </fo:block>
                    
                  </fo:list-item-body>
                </fo:list-item>
                
                 <fo:list-item>
              
              <fo:list-item-label>
              <fo:block></fo:block></fo:list-item-label>
              <fo:list-item-body>
             <fo:block  font-size="10px" color="grey" text-align="left" >LPL-AMEND-RI (04/17)
             <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 1 of 2</fo:block>
             </fo:block>
               <fo:block space-after="3mm" start-indent="21mm">If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to provide such notice, the coverage provided to the <fo:inline font-weight="bold">Named Insured</fo:inline> shall remain in effect until notice is provided or until the effective date or replacement coverage obtained by the <fo:inline font-weight="bold">Named Insured</fo:inline>, whichever occurs first.  For the purposes of this subsection, notice is considered given 60 days following the date of giving of the notice.  If the <fo:inline font-weight="bold">Named Insured</fo:inline> elects not to renew, any earned premium for the period of extension of the terminated policy shall be calculated pro-rata at the lower of the current or previous year’s rate.  If the <fo:inline font-weight="bold">Named Insured</fo:inline> accepts the renewal, the premium increase, if any, and other changes shall be effective the day following the prior policy’s expiration date.</fo:block>
                                    
                <fo:block  start-indent="21mm">This subsection shall not apply to changes based upon the altered nature or extent of the risk insured.</fo:block>
                   <fo:block margin-top="3mm"></fo:block>          
              </fo:list-item-body>
              </fo:list-item> 
             
                
                
                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>2.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body start-indent="15mm">
                    <fo:block space-after="3mm" start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section VI., General Conditions, is amended by addition of the following:
                      </fo:block>
                      <fo:block>

                        <fo:list-block>
                        <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline font-weight="bold">•</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="13mm">
                                <fo:inline font-weight="bold">Insured's Right to Loss Information</fo:inline>
                              </fo:block>
                              <fo:block margin-top="3mm"></fo:block>

                            </fo:list-item-body>
                          </fo:list-item>
                        
                        
                        
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline></fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="13mm">
                                Upon request by the <fo:inline font-weight="bold">Named Insured</fo:inline> or such <fo:inline font-weight="bold">Insured’s</fo:inline> authorized agent or broker, the <fo:inline font-weight="bold">Insurer</fo:inline> shall provide the following loss information, for the period of time coverage has been provided by the <fo:inline font-weight="bold">Insurer</fo:inline> or for five years, whichever is less, within 14 days of such request:
                              </fo:block>
                              <fo:block margin-top="3mm"></fo:block>
                              <fo:block start-indent="13mm">1.&#160;&#160;information on closed <fo:inline font-weight="bold">Claims</fo:inline>, including date and description of occurrence, and payments; and</fo:block>
                              <fo:block start-indent="13mm">2.&#160;&#160;information on open <fo:inline font-weight="bold">Claims</fo:inline>, including date and description of occurrence, and amounts of any payments and  &#160;&#160;&#160;&#160;&#160;loss reserves.</fo:block>

						<fo:block margin-top="3mm"></fo:block>
                      <fo:block  start-indent="13mm">Notwithstanding any other provision of this subsection, loss reserve information for <fo:inline font-weight="bold">Claims</fo:inline> subject to a documented coverage dispute between the <fo:inline font-weight="bold">Insurer</fo:inline> and the <fo:inline font-weight="bold">Insured</fo:inline> need not be provided to the <fo:inline font-weight="bold">Named Insured</fo:inline> or such <fo:inline font-weight="bold">Insured’s</fo:inline> authorized agent or broker.</fo:block>
                            </fo:list-item-body>
                          </fo:list-item>
                        </fo:list-block>
                      </fo:block>

                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
              </fo:list-block>

            </fo:block>
<fo:block margin-top="7mm"></fo:block>
            <fo:block>
              All other terms, conditions and limitations of the policy remain unaltered.
            </fo:block>

          </fo:block>
           <fo:block margin-top="16cm"/>
           <fo:block  font-size="10px" color="grey" text-align="left">LPL-AMEND-RI (04/17)
           <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 2 of 2</fo:block>
           </fo:block>
         
  </xsl:template>
 
</xsl:stylesheet>
