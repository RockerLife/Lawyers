<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo" xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
	<!-- <xsl:output method="xml" indent="no" /> -->
	<xsl:template match="/" name="LPL-AMEND-NH">
		<fo:block>
			<xsl:call-template name="CommonHeader" />
		</fo:block>
		<fo:block text-align="center" margin-left="1.3in"
			margin-right="1.3in" font-size="12px"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			space-before="7mm" space-after="7mm" font-weight="bold">

			NEW HAMPSHIRE AMENDATORY ENDORSEMENT

		</fo:block>
		<fo:block padding-left="5pt"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			font-size="10px" text-align="justify">

			<fo:block space-after="4mm">
				In consideration of the premium charged, it is agreed that:
			</fo:block>

		<fo:block space-after="4mm">
		
		<fo:list-block>
		<fo:list-item space-after="4mm">
		<fo:list-item-label>
		<fo:block>
		1.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="7mm">
		<fo:block space-after="4mm">
		Section III., Extension of Coverage D., Extended Reporting Period Extensions, is amended as follows:
		</fo:block>
		<fo:list-block>
		<fo:list-item space-after="4mm">
		<fo:list-item-label>
		<fo:block start-indent="7mm">
		a.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="14mm">
		<fo:block space-after="4mm">
		Subsection 1., Automatic Extended Reporting Period, is amended by deleting the phrase 
		“other than for cancellation of premium or for nonpayment of Deductible due hereunder”.
		</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		
		<fo:list-item space-after="4mm">
		<fo:list-item-label>
		<fo:block start-indent="7mm">
		b.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="14mm">
		<fo:block space-after="4mm">
		Subsection 2., Optional Extended Reporting Period, is amended as follows:
		</fo:block>
		<fo:list-block>
		<fo:list-item space-after="4mm">
		<fo:list-item-label>
		<fo:block start-indent="14mm">
		(1)
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="21mm">
		<fo:block space-after="4mm">
		The first paragraph is amended by deleting the phase “other than for nonpayment of premium or 
		for the nonpayment of Deductible due hereunder”
		</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		
		<fo:list-item>
		<fo:list-item-label>
		<fo:block start-indent="14mm">
		(2)
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="21mm">
		<fo:block space-after="4mm">
		The last paragraph is deleted and replaced with the following:
		</fo:block>
		<fo:block>
		When the Optional Extended Reporting Period applies, it replaces the Automatic Extended 
		Reporting Period.  However, if the duration of the Optional Extended Reporting Period 
		purchased is less than 14 months, the Optional Extended Reporting Period shall begin following 
		the end of the Automatic Extended Reporting Period.
		</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		</fo:list-block>
		</fo:list-item-body>
		</fo:list-item>
		
		<fo:list-item>
		<fo:list-item-label>
		<fo:block  start-indent="7mm">
		c.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="14mm">
		<fo:block space-after="4mm">
		Subsection 4., Conditions for Extended Reporting Periods, is deleted and replaced with the following:
		</fo:block>
		<fo:list-block>
		<fo:list-item>
		<fo:list-item-label>
		<fo:block start-indent="14mm">
		<fo:inline font-weight="bold">
		4.
		</fo:inline>
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="21mm">
		<fo:block space-after="4mm">
		Conditions for Extended Reporting Periods
		</fo:block>
		<fo:block>
		As a condition precedent to the right to elect an Extended Reporting Period:
		</fo:block>
		<fo:list-block space-after="4mm">
				<fo:list-item>
				<fo:list-item-label>
				<fo:block start-indent="21mm">
				(a)
				</fo:block>
				</fo:list-item-label>
				<fo:list-item-body>
				<fo:block start-indent="28mm">
				all <fo:inline font-weight="bold">Insureds</fo:inline> must be in compliance with the terms and conditions of the policy;
				</fo:block>
				</fo:list-item-body>
				</fo:list-item>
				<fo:list-item>
				<fo:list-item-label>
				<fo:block start-indent="21mm">
				(b)
				</fo:block>
				</fo:list-item-label>
				<fo:list-item-body>
				<fo:block start-indent="28mm">
				the <fo:inline font-weight="bold">Named Insured’s</fo:inline> right to practice law has not been revoked, suspended or 
				surrendered at the request of any regulatory authority for reasons other than death, 
				disability or retirement; and
				</fo:block>
				</fo:list-item-body>
				</fo:list-item>
				<fo:list-item>
				<fo:list-item-label>
				<fo:block start-indent="21mm">
				(c)
				</fo:block>
				</fo:list-item-label>
				<fo:list-item-body>
				<fo:block start-indent="28mm">
				the <fo:inline font-weight="bold">Named Insured</fo:inline> provides the <fo:inline font-weight="bold">Insurer</fo:inline> with written 
				notice of its selection and pays the premium charge, and any other monies due 
				and owing the <fo:inline font-weight="bold">Insurer</fo:inline>, if applicable, for the selected 
				Extended Reporting Period in full within 60 days of the expiration 
				date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.
				</fo:block>
				</fo:list-item-body>
				</fo:list-item>
				</fo:list-block>
				<fo:block space-after="4mm"></fo:block>
				<fo:block>
				This right to elect an Extended Reporting Period shall lapse unless the provisions of (a) through (c) in the preceding paragraph are fully met.
				</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		</fo:list-block>
		</fo:list-item-body>
		</fo:list-item>
		</fo:list-block>
		</fo:list-item-body>
		</fo:list-item>
		
		<fo:list-item space-after="4mm">
		<fo:list-item-label>
		<fo:block>
		2.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="7mm">
		<fo:block space-after="4mm">
		Section VI., General Condition D., Cancellation and Nonrenewal, paragraphs 2. and 3., are deleted and replaced with the following:
		</fo:block>
		<fo:list-block>
		<fo:list-item space-after="4mm">
		<fo:list-item-label>
		<fo:block start-indent="7mm">
		2.
		</fo:block>
		</fo:list-item-label>
		<fo:list-item-body start-indent="14mm">
		<fo:block space-after="4mm">
		The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium.  
		This policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or physically (not electronically) 
		delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline>, at the address shown in Item 1. of 
		the Declarations, written notice of cancellation at least 10 days before the effective date of 
		cancellation.  The reason for cancellation shall accompany or be included in the notice of cancellation.  
		The mailing of such notice by certified mail or certificate of mailing shall be sufficient 
		proof of notice and the effective date of cancellation stated in such notice shall become 
		the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  
		If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, 
		the <fo:inline font-weight="bold">Insurer</fo:inline> shall credit the <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of the premium.  
		Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline> shall not be a condition precedent 
		to the effectiveness of cancellation, but such payment shall be made within 30 days 
		of the date of cancellation as stated in the notice.
		</fo:block>
		</fo:list-item-body>
		</fo:list-item>
		</fo:list-block>
		</fo:list-item-body>
		</fo:list-item>
		
		</fo:list-block>

		</fo:block>
		<fo:block margin-top="2cm"/>
						<fo:block font-size="11px" color="grey" text-align="left">
						LPL-AMEND-NH (04/17)&#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160;&#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;&#160;
						&#160;&#160; &#160;&#160; &#160; &#160; &#160;&#160; &#160;&#160; &#160; Page 1 of 2
					</fo:block>
		</fo:block>
		<fo:block page-break-after="always"></fo:block>
		
		<fo:block padding-left="5pt"
			font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;"
			font-size="10px" text-align="justify">
			
			<fo:block space-after="4mm">
			
			<fo:list-block>
			<fo:list-item space-after="4mm">
			<fo:list-item-label>
			<fo:block start-indent="7mm">
			3.
			</fo:block>
			</fo:list-item-label>
			<fo:list-item-body start-indent="14mm">
			<fo:block space-after="4mm">
			The <fo:inline font-weight="bold">Insurer</fo:inline> shall not increase the renewal premium more than 25% 
			for a 12-month renewal term or refuse to renew this policy at its expiration unless 
			the <fo:inline font-weight="bold">Insurer</fo:inline> or its agent shall mail or physically (not electronically) deliver to 
			the <fo:inline font-weight="bold">Named Insured</fo:inline> at the address shown in the policy, advance notice of 
			the proposed renewal premium or its intention not to renew.  The notice shall be at least 60 days 
			in advance of the policy’s scheduled expiration.  This paragraph shall not apply if 
			the <fo:inline font-weight="bold">Insurer</fo:inline> has manifested its willingness to renew with a premium 
			increase of no more than 25%, or in case of nonpayment of premium, or if 
			the <fo:inline font-weight="bold">Named Insured</fo:inline> fails to pay any advance premium required by 
			the <fo:inline font-weight="bold">Insurer</fo:inline> for renewal.  However, notwithstanding the failure of 
			the <fo:inline font-weight="bold">Insurer</fo:inline> to comply with this paragraph, any coverage shall 
			terminate on the effective date of any other coverage acquired by 
			the <fo:inline font-weight="bold">Named Insured</fo:inline> to the extent the acquired coverage substantially 
			duplicates coverages of the renewal.
			</fo:block>
			<fo:block space-after="4mm">
			Any renewal premium increase of 25% or less shall not be implemented until 
			the <fo:inline font-weight="bold">Named Insured</fo:inline> has had a minimum of 30 days notice of the renewal premium.  
			If all or any part of the 30-day notice is not in advance of the expiration date, 
			renewal coverage shall be provided, on a pro rata basis, at the rates or premiums in effect 
			under the expiring policy until the 30 days notice requirement has been fulfilled.  
			This paragraph shall not apply if the <fo:inline font-weight="bold">Named Insured</fo:inline> accepts 
			the renewal policy.  Development of renewal premium for the purpose of determining 
			the percentage of change from expiring premium shall be based on the same coverages, 
			conditions, and ratable exposures as those contained in the expiring policy.
			</fo:block>
			</fo:list-item-body>
			</fo:list-item>
			
			<fo:list-item space-after="4mm">
			<fo:list-item-label>
			<fo:block>
			3.
			</fo:block>
			</fo:list-item-label>
			<fo:list-item-body start-indent="7mm">
			<fo:block space-after="4mm">
			Subsection VI., General Condition E., Changes in Exposure, paragraph 1., is deleted and replaced with the following:
			</fo:block>
			<fo:list-block>
			<fo:list-item>
			<fo:list-item-label>
			<fo:block start-indent="7mm">
			1.
			</fo:block>
			</fo:list-item-label>
			<fo:list-item-body start-indent="14mm">
			<fo:block space-after="4mm">
			If the number of attorneys employed by the <fo:inline font-weight="bold">Named Insured</fo:inline> increases more than 25% 
			from the amount of attorneys shown in the application attached to this policy at 
			its inception date, the <fo:inline font-weight="bold">Named Insured</fo:inline> shall give the <fo:inline font-weight="bold">Insurer</fo:inline> notice of such hiring, 
			merger or acquisition as soon as practicable, but in no event more than 30 days after 
			the effective date of hiring, merger or acquisition.  The <fo:inline font-weight="bold">Insurer</fo:inline> 
			shall then have the right to accept, alter or decline coverage and to charge an additional premium.  
			This paragraph shall not be applicable if the original number of attorneys 
			insured on the effective date of this policy was less than six attorneys.
			</fo:block>
			</fo:list-item-body>
			</fo:list-item>
			</fo:list-block>
			</fo:list-item-body>
			</fo:list-item>
			
			<fo:list-item space-after="6mm">
			<fo:list-item-label>
			<fo:block>
			4.
			</fo:block>
			</fo:list-item-label>
			<fo:list-item-body start-indent="7mm">
			<fo:block space-after="4mm">
			Section VI., General Condition M., <fo:inline font-weight="bold">Named Insured</fo:inline> 
			Sole Agent, paragraph 2., is deleted and replaced with the following:
			</fo:block>
			<fo:list-block>
			<fo:list-item>
			<fo:list-item-label>
			<fo:block start-indent="7mm">
			2.
			</fo:block>
			</fo:list-item-label>
			<fo:list-item-body start-indent="14mm">
			<fo:block space-after="4mm">
			for the completing of any applications and the making of any statements and representations for the policy; and
			</fo:block>
			</fo:list-item-body>
			</fo:list-item>
			</fo:list-block>
			</fo:list-item-body>
			</fo:list-item>
			
			<fo:list-item>
			<fo:list-item-label>
			<fo:block></fo:block>
			</fo:list-item-label>
			<fo:list-item-body start-indent="4mm">
			<fo:block space-after="4mm">
			All other terms, conditions and limitations of the policy remain unaltered.
			</fo:block>
			</fo:list-item-body>
			</fo:list-item>
			</fo:list-block>
			
			</fo:block>
			
		<fo:block margin-top="13cm"/>
						<fo:block font-size="11px" color="grey" text-align="left">
						LPL-AMEND-NH (04/17)&#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160;&#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160;
						&#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160; &#160;&#160;
						&#160;&#160; &#160;&#160; &#160; &#160; &#160;&#160; &#160;&#160; &#160; Page 2 of 2
					</fo:block>
		</fo:block>
		<fo:block page-break-before="auto"></fo:block>
</xsl:template>
</xsl:stylesheet>