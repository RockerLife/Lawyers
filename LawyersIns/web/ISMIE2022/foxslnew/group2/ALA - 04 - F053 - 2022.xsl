<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
  <!-- <xsl:output method="xml" indent="no" /> -->
  <xsl:template match="/" name="ALA04F053">
    
		<fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		</fo:block>
          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="4mm" space-after="1cm"  font-weight="bold">

            TENNESSEE AMENDATORY ENDORSEMENT

          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that Section VI., General Condition D., Cancellation and Nonrenewal, is amended as follows:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>

                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.	</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                        Paragraph 2. is amended by addition of the following:
                      </fo:block>
                      <fo:block start-indent="7mm">Notice of cancellation shall state the reason for cancellation.</fo:block>
                      <fo:block  margin-top="3mm"></fo:block>
                   
                   </fo:block>
                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block>2.</fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>
                            <fo:block start-indent="7mm" space-after="3mm">
                                        <fo:inline >Paragraph 3. is deleted and replaced with the following:</fo:inline>
                                      </fo:block >
                                    
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="7mm">
                                              <fo:inline>3.</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="14mm">
                                             Unless the <fo:inline font-weight="bold">Insurer</fo:inline>, at least 60 days in advance of the end of the 
                                             <fo:inline font-weight="bold">Policy Period</fo:inline>, mails or delivers to the <fo:inline font-weight="bold">Named Insured</fo:inline> 
                                             and agent at the address shown in the policy, notice of its intention not to renew the policy or to condition its renewal on reduction 
                                             of the Limit of Liability or elimination of coverages, the <fo:inline font-weight="bold">Insurer</fo:inline> 
                                             shall extend the existing policy 60 days from the date the notice is provided.  The premium for the extension provided in those 
                                             circumstances shall be no more than a pro rata basis of the existing policy. 
                                             Notice of nonrenewal is not required if: (a) the <fo:inline font-weight="bold">Insurer</fo:inline> has offered to issue a renewal 
                                             policy; or (b) where the <fo:inline font-weight="bold">Named Insured</fo:inline> has obtained replacement coverage or has agreed in 
                                             writing to obtain replacement coverage.  If an <fo:inline font-weight="bold">Insurer</fo:inline> provides the notice described in 
                                             this paragraph, and thereafter the <fo:inline font-weight="bold">Insurer</fo:inline> extends the policy for 90 days or less, an 
                                             additional notice of nonrenewal is not required with respect to the extension.
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>
                                        
                                        </fo:list-block></fo:list-item-body></fo:list-item></fo:list-block></fo:block>
                                         <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block>3.</fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>
                            <fo:block start-indent="7mm" space-after="3mm">
                                        <fo:inline >The following paragraph is added:</fo:inline>
                                      </fo:block >
                                    
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="7mm">
                                              <fo:inline>•</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="14mm">
                                             In the event the <fo:inline font-weight="bold">Insurer</fo:inline> intends to increase the premium of this policy by an amount 
                                             that is more than 25% and the increase in premium is the result of comparing policies of equivalent exposures, the 
                                             <fo:inline font-weight="bold">Insurer</fo:inline> shall mail or deliver to the <fo:inline font-weight="bold">Named Insured</fo:inline> 
                                             and producer at the address shown on the policy, not less than 60 days prior notice of its intention to increase the premium, 
                                             specifying the percentage of the increase.  Unless notice is provided as described in this paragraph, 
                                             the <fo:inline font-weight="bold">Insurer</fo:inline> shall extend the existing policy 60 days from the date the notice is provided. 
                                             The premium for the extension provided in those circumstances shall not be more than a pro rata basis of the existing policy.
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>
                                        
                                        </fo:list-block></fo:list-item-body></fo:list-item></fo:list-block></fo:block>
                                        <fo:block margin-top="5mm"></fo:block>
                                        
                                        <fo:block >All other terms, conditions and limitations of the policy remain unaltered.</fo:block>
                                        
                                        
                              <fo:block margin-top="8cm"></fo:block>          
                           <fo:block  font-size="10px" color="grey" text-align="left">ISMIE ALA-04-F053 (03/01/2022)
                           <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 1 of 1</fo:block>
                           </fo:block> 
         
                                        
                                        
                                        
                                        </fo:list-item-body></fo:list-item></fo:list-block></fo:block>
                                        </fo:block> 
                                        </xsl:template></xsl:stylesheet>