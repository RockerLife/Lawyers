<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
  <!-- <xsl:output method="xml" indent="no" /> -->
  <xsl:template match="/" name="ALA04F027">
    
		<fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		</fo:block>
          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="4mm" space-after="4mm"  font-weight="bold">

            NEVADA AMENDATORY ENDORSEMENT

          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>

                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.	</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
                      </fo:block>
                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline font-weight="bold">D. </fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                <fo:inline font-weight="bold"> Cancellation, Nonrenewal, Conditional Renewal and Claims Information</fo:inline>
                              </fo:block>
                              <fo:block>
                                <fo:list-block>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">1.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Cancellation</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the expiration date of the
                                              <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written notice to the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline> or its authorized
                                              agent.  If the <fo:inline font-weight="bold">Named Insured</fo:inline> cancels this policy, the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> shall return 90% of the unearned portion of the premium.
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(b)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              <fo:block space-after="3mm">
                                                
                                                	The <fo:inline font-weight="bold"> Insurer</fo:inline> may only cancel this policy for nonpayment of premium or Deductible.  This policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by personally delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline>, or by mailing by first class or certified mail to the <fo:inline font-weight="bold">Named Insured</fo:inline>, at the address at of the <fo:inline font-weight="bold">Named Insured</fo:inline> last known by the <fo:inline font-weight="bold">Insurer</fo:inline>, written notice of cancellation at least:

                                              </fo:block>
                                              <fo:block >(1) &#160;&#160; 10 days before the effective date of cancellation for nonpayment of premium; or</fo:block>
                                              <fo:block>(2) &#160;&#160; 30 days before the effective date of cancellation for nonpayment of Deductible.</fo:block>
                                             <fo:block margin-top="3mm"></fo:block>
                                            <fo:block> Such notice shall be accompanied by a written explanation of the specific reasons for the cancellation.  The mailing of such notice shall be sufficient proof of notice and the effective date of cancellation stated in such notice shall become the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall credit the <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of the premium.  Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline> shall not be a condition precedent to the effectiveness of cancellation, but such payment shall be made as soon as practicable.</fo:block>
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">2. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Nonrenewal</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                           <fo:block></fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="21mm" space-after="3mm">
                                             
                                            This policy may be nonrenewed by the <fo:inline font-weight="bold">Insurer</fo:inline> by personally delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline>, or by mailing by first class or certified mail to the <fo:inline font-weight="bold">Named Insured</fo:inline>, at the address of the <fo:inline font-weight="bold">Named Insured</fo:inline> last known by the <fo:inline font-weight="bold">Insurer</fo:inline>, written notice of nonrenewal at least 60 days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  Such notice shall be accompanied by a written explanation of the specific reasons for the nonrenewal.  The mailing of such notice shall be sufficient proof of notice.
                                              
                                            </fo:block>
                                            <fo:block start-indent="21mm" space-after="3mm">If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to provide a timely notice of nonrenewal, the <fo:inline font-weight="bold">Insurer</fo:inline> shall provide the <fo:inline font-weight="bold">Named Insured</fo:inline> with a policy of insurance on the identical terms as in the expiring policy.

                                            </fo:block>
                                            
                                            
                                            <fo:block start-indent="21mm" space-after="3mm">This subsection does not apply if the <fo:inline font-weight="bold">Named Insured</fo:inline> has accepted replacement coverage or has requested or agreed to nonrenewal.</fo:block>
                                            
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                 

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>

                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">3. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Conditional Renewal</fo:inline>
                                      </fo:block>
                                      <fo:list-block space-after="3mm">
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block></fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="21mm">

                                              The <fo:inline font-weight="bold">Insurer</fo:inline> shall not renew this policy on different terms, including different rates, unless the <fo:inline font-weight="bold">Insurer</fo:inline> notifies the <fo:inline font-weight="bold">Named Insured</fo:inline> in writing of the different terms or rates at least 30 days before the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to provide adequate and timely notice, the <fo:inline font-weight="bold">Insurer</fo:inline> shall renew the policy at the expiring terms and rates.
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  
                                  
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">4. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Claims Information</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block></fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="21mm">
                                              
                                              If the <fo:inline font-weight="bold">Named Insured</fo:inline> requests information for the renewal of its policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall provide to the <fo:inline font-weight="bold">Named Insured</fo:inline> information regarding <fo:inline font-weight="bold">Claims</fo:inline> paid on its behalf.  The information must be provided within 30 workings days after the <fo:inline font-weight="bold">Insurer</fo:inline> receives a written request from the <fo:inline font-weight="bold">Named Insured</fo:inline>.
                                            </fo:block>
                                         
                                          </fo:list-item-body>
                                       
                                          
                                        </fo:list-item>

                                    

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>

                                </fo:list-block>
                              </fo:block>
<fo:block margin-top="5mm"></fo:block>
         
                            </fo:list-item-body>
                          </fo:list-item>

                        </fo:list-block>
                      </fo:block>

                    </fo:block>
                     
                  </fo:list-item-body>
                </fo:list-item>
          <fo:list-item>
              
              <fo:list-item-label>
              <fo:block></fo:block></fo:list-item-label>
              <fo:list-item-body>
              <fo:block margin-top="1mm"/>
              
              
              
           <fo:block  font-size="10px" color="grey" text-align="left">ISMIE ALA-04-F027 (09/01/2021)
           <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 1 of 2</fo:block>
           </fo:block>
          
         
           
              </fo:list-item-body>
              </fo:list-item> 
             


                <fo:list-item>
                  <fo:list-item-label>
                  
                    <fo:block>
                      <fo:inline>2. </fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                       Section VI., General Condition M., <fo:inline font-weight="bold">Named Insured</fo:inline> Sole Agent, paragraph 2., is deleted and replaced with the following:
                      </fo:block>


                      <fo:block start-indent="7mm" space-after="6mm">
                        2. &#160;&#160;for the completing of any applications and the making of any statements and representations for the policy; and
                      </fo:block>

                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
              </fo:list-block>

            </fo:block>

            <fo:block margin-top="3mm">
              All other terms, conditions and limitations of the policy remain unaltered.
            </fo:block>
          </fo:block>
        
           <fo:block margin-top="25cm"/>
           
          
           <fo:block  font-size="10px" color="grey" text-align="left">ISMIE ALA-04-F027 (09/01/2021)
           <fo:block margin-top="-0.5cm" font-size="10px" color="grey" text-align="right">Page 2 of 2</fo:block>
           </fo:block>
           
         
  </xsl:template> 
</xsl:stylesheet>
