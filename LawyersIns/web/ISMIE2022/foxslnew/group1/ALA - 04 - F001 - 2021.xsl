<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
 
  <xsl:template match="/" name="ALA04F001">
     	   <fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		  </fo:block>

          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="5mm" space-after="5mm" font-weight="bold">

            FLORIDA AMENDATORY ENDORSEMENT


          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>
                <fo:list-item space-after="4mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                      Section III., Extension of Coverage B., Spousal and Domestic Partner Extension, is amended by deleting the phrase “lawful domestic partner” and replacing it with “lawful domestic partner recognized under the provisions of any applicable federal, state or local law in the United States of America”.
                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
                <fo:list-item space-after="4mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>2.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                     Section IV., Definition E., <fo:inline font-weight="bold">Damages</fo:inline>, paragraph 3., is amended by addition of the following:
                    </fo:block>
                    
                     <fo:block space-after="3mm" start-indent="7mm">
                     Provided, however, punitive damages are not insurable in Florida.
                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
                 <fo:list-item space-after="4mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>3.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                     Section III., Extension of Coverage D., Extended Reporting Period Extensions, subsection 4., Conditions for Optional Extended Reporting Periods, is amended by deleting the word “precedent”.
                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
                
                 <fo:list-item space-after="4mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>4.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                    Section VI., General Condition C., Action Against Insurer, paragraph 1., is deleted and replaced with the following:
                    </fo:block>
                    
                     <fo:block>
                     <fo:list-block>
                     <fo:list-item>
                     <fo:list-item-label>
                     <fo:block space-after="3mm" start-indent="7mm">1.</fo:block>
                     </fo:list-item-label>
                     
                     <fo:list-item-body>
                    <fo:block space-after="3mm" start-indent="12mm">
						No action shall be taken against the Insurer unless the Insureds shall
						have fully complied with all of the terms and conditions of this
						policy, nor until the amount of the Insured’s obligation to pay Damages
						for any Claim shall have been fully and finally determined either by
						judgment against the Insured or by written agreement between the
						Insureds, the claimant, and the Insurer.
                    </fo:block>
                     </fo:list-item-body>
                     </fo:list-item>
                     </fo:list-block>
                     </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
                <fo:list-item space-after="4mm">
                <fo:list-item-label>
                <fo:block>
                5.
                </fo:block>
                </fo:list-item-label>
                <fo:list-item-body start-indent="7mm">
                <fo:block space-after="4mm">
                	Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
                </fo:block>
                <fo:block>
                <fo:list-block>
                <fo:list-item space-after="4mm">
                	<fo:list-item-label>
                	<fo:block font-weight="bold">
                		D.
                	</fo:block>
                	</fo:list-item-label>
                	<fo:list-item-body start-indent="14mm">
                	<fo:block font-weight="bold" space-after="4mm">
                		Cancellation, Nonrenewal or Renewal Premium, and Change in Policy Terms
                	</fo:block>
                	<fo:block>
                	<fo:list-block>
                	<fo:list-item space-after="4mm">
                	<fo:list-item-label>
                	<fo:block font-weight="bold">
                		1.
                	</fo:block>
                	</fo:list-item-label>
                	<fo:list-item-body start-indent="21mm">
                	<fo:block font-weight="bold" space-after="4mm">
                		Cancellation
                	</fo:block>
                	<fo:block>
                	<fo:list-block>
                	<fo:list-item space-after="4mm">
                	<fo:list-item-label>
                	<fo:block>
                		(a)
                	</fo:block>
                	</fo:list-item-label>
                	<fo:list-item-body start-indent="28mm">
                	<fo:block>
						The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the
						expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written notice
						to the <fo:inline font-weight="bold">Insurer</fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline> or its
						authorized agent. If the <fo:inline font-weight="bold">Named Insured</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline>
						shall return 90% of the unearned portion of the premium.
                	</fo:block>
                	</fo:list-item-body>
                	</fo:list-item>
                	<fo:list-item space-after="4mm">
                	<fo:list-item-label>
                	<fo:block>
                		(b)
                	</fo:block>
                	</fo:list-item-label>
                	<fo:list-item-body start-indent="28mm">
                	<fo:block space-after="3mm">
						The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium or
						Deductible. This policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or
						delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline>, at the address shown in Item 1. of the
						Declarations, written notice of cancellation at least 10 days before
						the effective date of cancellation. The effective date of cancellation
						stated in such notice shall become the expiration date of the <fo:inline font-weight="bold">Policy
						Period</fo:inline>. If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall credit
						the <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of the premium.
                	</fo:block>
                	
                	<fo:block start-indent="21mm">
						Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline> is not a
						condition of cancellation, but such payment shall be mailed within 15
						working days after the effective date of cancellation.
                	</fo:block>
                	</fo:list-item-body>
                	</fo:list-item>
                	</fo:list-block>
                	</fo:block>
                	</fo:list-item-body>
                	</fo:list-item>
                	<fo:list-item space-after="4mm">
                	<fo:list-item-label>
                	<fo:block font-weight="bold">
                		2.
                	</fo:block>
                	</fo:list-item-label>
                	<fo:list-item-body start-indent="21mm">
                	<fo:block font-weight="bold" space-after="4mm">
                		Nonrenewal or Renewal Premium
                	</fo:block>
                	<fo:block space-after="4mm">
						The <fo:inline font-weight="bold">Insurer</fo:inline> shall mail or deliver to the <fo:inline font-weight="bold">Named Insured</fo:inline>, at the address
						shown in Item 1. of the Declarations, at least 45 days advance written
						notice of nonrenewal or of the renewal premium. This requirement
						applies only if the <fo:inline font-weight="bold">Insured</fo:inline> has furnished all the necessary information
						so as to enable the <fo:inline font-weight="bold">Insurer</fo:inline> to develop the renewal premium prior to the
						expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.
                	</fo:block>
                	
                	</fo:list-item-body>
                	</fo:list-item>
                	</fo:list-block>
                	</fo:block>
                	</fo:list-item-body>
                </fo:list-item>
                </fo:list-block>
                </fo:block>
                </fo:list-item-body>
                </fo:list-item>
               </fo:list-block>
                	
                
	           	<fo:block margin-top="1.5cm" font-size="9px" color="grey" text-align="left">ISMIE ALA-04-F001 (09/01/2021) &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
	           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
	           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
	           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
	           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
	          Page 1 of 2</fo:block>
	          
	           
	           
            </fo:block>
            
            
            
               <fo:block break-after="page" />
          			
                	
                	<fo:block space-after="4mm" start-indent="21mm">
						If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to provide the 45-day written notice required
						under this subsection, the coverage provided to the <fo:inline font-weight="bold">Named Insured</fo:inline> shall
						remain in effect until 45 days after the notice is given or until the
						effective date of replacement coverage obtained by the <fo:inline font-weight="bold">Named Insured</fo:inline>,
						whichever occurs first. The premium for the coverage shall remain the
						same during any such extension period except that, if the rate filing
						then in effect would have resulted in a premium reduction, the premium
						during such extension of coverage shall be calculated based upon the
						later rate filing.
                	</fo:block>
                	<fo:block start-indent="14mm" space-after="4mm">
						Notice of cancellation or nonrenewal by the <fo:inline font-weight="bold">Insurer</fo:inline> shall be
						accompanied by the specific reasons for cancellation or nonrenewal,
						including the specific underwriting reasons, if applicable. If notice
						of cancellation or nonrenewal is mailed by the <fo:inline font-weight="bold">Insurer</fo:inline>, proof of
						mailing may be provided by use of the certified or registered mail
						services of the U.S. Postal Service or by a U.S. Postal Services proof
						of mailing form. The certification or registration receipts or the
						proof of mailing form shall state the name of the <fo:inline font-weight="bold">Named Insured</fo:inline>, the
						policy number and the date mailed. Alternatively, the <fo:inline font-weight="bold">Insurer</fo:inline> may
						establish any other system to provide proof of notice of cancellation
						or nonrenewal so long as the system clearly indicates the method of notification and the name of the Named Insured, the policy number and the date mailed.
                	</fo:block>
                	
   			
       			<fo:block space-after="8mm">
					<fo:list-block>
						<fo:list-item space-after="4mm">
							<fo:list-item-label>
								<fo:block></fo:block>
							</fo:list-item-label>
							<fo:list-item-body start-indent="14mm">
								<!-- <fo:block margin-top="5mm" space-after="4mm">
									so long as the system clearly indicates the method of notification and the name of the Named Insured, the policy number and the date mailed.
								</fo:block> -->
								<fo:block>
									Upon expiration of the <fo:inline font-weight="bold">Policy Period</fo:inline>, the <fo:inline font-weight="bold">Insurer</fo:inline> may transfer the
									policy to another authorized insurer that is a member of the same group
									or owned by the same holding company as the transferring <fo:inline font-weight="bold">Insurer</fo:inline>. The
									transfer constitutes a renewal of the policy and may not be treated as
									a cancellation or a nonrenewal of the policy. The <fo:inline font-weight="bold">Insurer</fo:inline> must provide
									notice of its intent to transfer the policy at least 45 days before the
									effective date of the transfer along with the financial rating of the
									authorized insurer to which the policy is being transferred. Such
									notice may be provided in the notice of renewal premium.
								</fo:block>
							</fo:list-item-body>
						</fo:list-item>
						<fo:list-item space-after="4mm">
						<fo:list-item-label start-indent="14mm">
						<fo:block font-weight="bold">
							3.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="21mm">
						<fo:block font-weight="bold" space-after="4mm">
							Change in Policy Terms
						</fo:block>
						<fo:block space-after="4mm">
							A renewal policy may contain a change in policy terms. If such change
							occurs, the <fo:inline font-weight="bold">Insurer</fo:inline> shall give the <fo:inline font-weight="bold">Named Insured</fo:inline> at least 45 days
							advance written notice of the change, which may be enclosed along with
							the written notice of renewal premium. The <fo:inline font-weight="bold">Insurer</fo:inline> must also provide a
							sample copy of the notice to the <fo:inline font-weight="bold">Named Insured’s</fo:inline> insurance agent before
							or at the same time that notice is provided to the <fo:inline font-weight="bold">Named Insured</fo:inline>. Such
							notice shall be entitled “Notice of Change in Policy Terms”.
						</fo:block>
						<fo:block space-after="4mm">
							A renewal policy, which includes the addition of optional coverage that
							increases the premium to the <fo:inline font-weight="bold">Named Insured</fo:inline>, may not use the Notice of
							Change in Policy Terms to add the optional coverage to the policy
							unless the <fo:inline font-weight="bold">Named Insured</fo:inline> affirmatively indicates to the <fo:inline font-weight="bold">Insurer</fo:inline> or
							agent that it approves the additional of the optional coverage.
						</fo:block>
						<fo:block space-after="4mm">
							Although not required, proof of mailing or registered mailing through
							the U.S. Postal Service of the Notice of Change in Policy Terms to the
							<fo:inline font-weight="bold">Named Insured</fo:inline> at the address shown in the policy is sufficient proof of
							notice.
						</fo:block>
						<fo:block space-after="4mm">
							Receipt of the premium payment for the renewal policy by the <fo:inline font-weight="bold">Insurer</fo:inline> is
							deemed to be acceptance of the new policy terms by the <fo:inline font-weight="bold">Named Insured</fo:inline>.
						</fo:block>
						<fo:block space-after="4mm">
							If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to provide the notice required in this subsection,
							the original policy terms remain in effect until the next renewal and
							the proper service of the notice, or until the effective date of
							replacement coverage obtained by the <fo:inline font-weight="bold">Named Insured</fo:inline>, whichever occurs
							first.
						</fo:block>
						<fo:block>
							As used in this subsection, the term:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(a)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							“change in policy terms” means the modification, addition, or deletion of any term, coverage, duty, or condition from the previous policy; and
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							(b)
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="28mm">
						<fo:block>
							“optional coverage” means the addition of new insurance coverage that
							has not previously been requested or approved by the <fo:inline font-weight="bold">Named Insured</fo:inline> but
							that does not include any change to the base policy, the Deductible or
							the Limit of Liability.
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							6.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="7mm">
						<fo:block space-after="4mm">
							Section VI., General Condition M., <fo:inline font-weight="bold">Named Insured</fo:inline> Sole Agent,
							paragraph 2., is deleted and replaced with the following:
						</fo:block>
						<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block>
							2.
						</fo:block>
						</fo:list-item-label>
						<fo:list-item-body start-indent="14mm">
						<fo:block>
							for the completing of any applications and the making of any statements and representations for the policy; and
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						</fo:list-block>
						</fo:block>
						</fo:list-item-body>
						</fo:list-item>
					</fo:list-block>
				</fo:block>
				<fo:block>
					All other terms, conditions and limitations of the policy remain unaltered.
				</fo:block>
          
        <fo:block margin-top="1.5cm" font-size="9px" color="grey" text-align="left">ISMIE ALA-04-F001 (09/01/2021) &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
