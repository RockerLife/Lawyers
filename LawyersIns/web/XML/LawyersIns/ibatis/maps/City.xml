<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="City">
     <select id="findAll" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from City</select>
     <select id="findAllByPartialKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from City where CountyKey = #CountyKey#</select>
     <insert id="insert" parameterClass="java.util.HashMap">
          insert into City(CountyKey
          <isNotEmpty property="CityDesc" prepend=",">CityDesc</isNotEmpty>
          ) values (#CountyKey:NUMERIC#
          <isNotEmpty property="CityDesc" prepend=",">#CityDesc#</isNotEmpty>
          )
          <selectKey resultClass="int" keyProperty="CityKey">SELECT IDENT_CURRENT('City') as last_insert_id</selectKey>
     </insert>
     <select id="updateFindByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select CityKey, CityDesc, CountyKey from City where CityKey = #CityKey# and CountyKey = #CountyKey#</select>
     <update id="update" parameterClass="java.util.HashMap">
          update City set
          <dynamic prepend=" ">
               <isNotEmpty property="CityDesc" prepend=",">CityDesc = #CityDesc#</isNotEmpty>
               <isEmpty property="CityDesc" prepend=",">CityDesc = null</isEmpty>
          </dynamic>
          where CityKey = #CityKey# and CountyKey = #CountyKey#
     </update>
     <delete id="delete" parameterClass="java.util.HashMap">delete from City where CityKey = #CityKey# and CountyKey = #CountyKey#</delete>
     <delete id="deleteAll" parameterClass="java.util.HashMap">delete from City</delete>
     <delete id="deleteAllByPartialKey" parameterClass="java.util.HashMap">delete from City where CountyKey = #CountyKey#</delete>
     <select id="findByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select CityKey, CityDesc, CountyKey from City where CityKey = #CityKey# and CountyKey = #CountyKey#</select>
     <select id="search" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select CityKey, CountyKey, CityDesc from City where CountyKey = #CountyKey#</select>
</sqlMap>

