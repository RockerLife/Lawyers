<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="LOB">
     <select id="getBrokerageLOBDetails" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select LOBKey,LOBDesc_Brokerage as LOBDesc from LOB order by LOBKey</select>
     <select id="findAll" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from LOB</select>
     <select id="findAllByPartialKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from LOB</select>
     <insert id="insert" parameterClass="java.util.HashMap">
          insert into LOB(
          <dynamic prepend=" ">
               <isNotEmpty property="LOBDesc" prepend=",">LOBDesc</isNotEmpty>
               <isNotEmpty property="LastUpdateUserID" prepend=",">LastUpdateUserID</isNotEmpty>
               <isNotEmpty property="LastUpdateTimeStamp" prepend=",">LastUpdateTimeStamp</isNotEmpty>
          </dynamic>
          ) values (
          <dynamic prepend=" ">
               <isNotEmpty property="LOBDesc" prepend=",">#LOBDesc#</isNotEmpty>
               <isNotEmpty property="LastUpdateUserID" prepend=",">#LastUpdateUserID#</isNotEmpty>
               <isNotEmpty property="LastUpdateTimeStamp" prepend=",">#LastUpdateTimeStamp#</isNotEmpty>
          </dynamic>
          )
          <selectKey resultClass="int" keyProperty="LOBKey">SELECT IDENT_CURRENT('LOB') as last_insert_id</selectKey>
     </insert>
     <select id="updateFindByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select LOBKey, LOBDesc, LastUpdateUserID, LastUpdateTimeStamp from LOB where LOBKey = #LOBKey#</select>
     <update id="update" parameterClass="java.util.HashMap">
          update LOB set
          <dynamic prepend=" ">
               <isNotEmpty property="LOBDesc" prepend=",">LOBDesc = #LOBDesc#</isNotEmpty>
               <isEmpty property="LOBDesc" prepend=",">LOBDesc = null</isEmpty>
               <isNotEmpty property="LastUpdateUserID" prepend=",">LastUpdateUserID = #LastUpdateUserID#</isNotEmpty>
               <isEmpty property="LastUpdateUserID" prepend=",">LastUpdateUserID = null</isEmpty>
               <isNotEmpty property="LastUpdateTimeStamp" prepend=",">LastUpdateTimeStamp = #LastUpdateTimeStamp#</isNotEmpty>
               <isEmpty property="LastUpdateTimeStamp" prepend=",">LastUpdateTimeStamp = null</isEmpty>
          </dynamic>
          where LOBKey = #LOBKey#
     </update>
     <delete id="delete" parameterClass="java.util.HashMap">delete from LOB where LOBKey = #LOBKey#</delete>
     <delete id="deleteAll" parameterClass="java.util.HashMap">delete from LOB</delete>
     <delete id="deleteAllByPartialKey" parameterClass="java.util.HashMap">delete from LOB</delete>
     <select id="findByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select LOBKey, LOBDesc, LastUpdateUserID, LastUpdateTimeStamp from LOB where LOBKey = #LOBKey#</select>
     <select id="search" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select LOBKey, LOBDesc, LastUpdateUserID, LastUpdateTimeStamp from LOB</select>
</sqlMap>

