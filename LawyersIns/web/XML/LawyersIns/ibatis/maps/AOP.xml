<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="AOP">
     <select id="findAll" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from AOP</select>
     <select id="findAllByPartialKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from AOP</select>
     <insert id="insert" parameterClass="java.util.HashMap">
          insert into AOP(
          <dynamic prepend=" ">
               <isNotEmpty property="AOPDesc" prepend=",">AOPDesc</isNotEmpty>
          </dynamic>
          ) values (
          <dynamic prepend=" ">
               <isNotEmpty property="AOPDesc" prepend=",">#AOPDesc#</isNotEmpty>
          </dynamic>
          )
          <selectKey resultClass="int" keyProperty="AOPKey">SELECT IDENT_CURRENT('AOP') as last_insert_id</selectKey>
     </insert>
     <select id="updateFindByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select AOPKey, AOPDesc from AOP where AOPKey = #AOPKey#</select>
     <update id="update" parameterClass="java.util.HashMap">
          update AOP set
          <dynamic prepend=" ">
               <isNotEmpty property="AOPDesc" prepend=",">AOPDesc = #AOPDesc#</isNotEmpty>
               <isEmpty property="AOPDesc" prepend=",">AOPDesc = null</isEmpty>
          </dynamic>
          where AOPKey = #AOPKey#
     </update>
     <delete id="delete" parameterClass="java.util.HashMap">delete from AOP where AOPKey = #AOPKey#</delete>
     <delete id="deleteAll" parameterClass="java.util.HashMap">delete from AOP</delete>
     <delete id="deleteAllByPartialKey" parameterClass="java.util.HashMap">delete from AOP</delete>
     <select id="findByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select AOPKey, AOPDesc from AOP where AOPKey = #AOPKey#</select>
     <select id="search" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select AOPKey, AOPDesc from AOP</select>
</sqlMap>

