<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="Country">
     <select id="findAll" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from Country</select>
     <select id="findAllByPartialKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from Country</select>
     <insert id="insert" parameterClass="java.util.HashMap">
          insert into Country(
          <dynamic prepend=" ">
               <isNotEmpty property="CountryDesc" prepend=",">CountryDesc</isNotEmpty>
          </dynamic>
          ) values (
          <dynamic prepend=" ">
               <isNotEmpty property="CountryDesc" prepend=",">#CountryDesc#</isNotEmpty>
          </dynamic>
          )
          <selectKey resultClass="int" keyProperty="CountryKey">SELECT IDENT_CURRENT('Country') as last_insert_id</selectKey>
     </insert>
     <select id="updateFindByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select CountryKey, CountryDesc from Country where CountryKey = #CountryKey#</select>
     <update id="update" parameterClass="java.util.HashMap">
          update Country set
          <dynamic prepend=" ">
               <isNotEmpty property="CountryDesc" prepend=",">CountryDesc = #CountryDesc#</isNotEmpty>
               <isEmpty property="CountryDesc" prepend=",">CountryDesc = null</isEmpty>
          </dynamic>
          where CountryKey = #CountryKey#
     </update>
     <delete id="delete" parameterClass="java.util.HashMap">delete from Country where CountryKey = #CountryKey#</delete>
     <delete id="deleteAll" parameterClass="java.util.HashMap">delete from Country</delete>
     <delete id="deleteAllByPartialKey" parameterClass="java.util.HashMap">delete from Country</delete>
     <select id="findByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select CountryKey, CountryDesc from Country where CountryKey = #CountryKey#</select>
     <select id="search" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select CountryKey, CountryDesc from Country</select>
</sqlMap>

