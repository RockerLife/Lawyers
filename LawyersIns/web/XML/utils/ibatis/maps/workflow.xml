<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="workflow">
     <select id="findBusinessflowsByProjectId" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">
     	select * from businessflows where project = #project#
     </select>
</sqlMap>
