<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="systemrule">
     <select id="findAll" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from systemrule</select>
     <select id="findAllByPartialKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from systemrule where structureno = #structureno#</select>
     <insert id="insert" parameterClass="java.util.HashMap">
          insert into systemrule(structureno, name
          <isNotEmpty property="expression" prepend=",">expression</isNotEmpty>
          <isNotEmpty property="event" prepend=",">event</isNotEmpty>
          <isNotEmpty property="input" prepend=",">input</isNotEmpty>
          <isNotEmpty property="output" prepend=",">output</isNotEmpty>
          <isNotEmpty property="deltaind" prepend=",">deltaind</isNotEmpty>
          <isNotEmpty property="description" prepend=",">description</isNotEmpty>
          ) values (#structureno:NUMERIC#, #name#
          <isNotEmpty property="expression" prepend=",">#expression#</isNotEmpty>
          <isNotEmpty property="event" prepend=",">#event#</isNotEmpty>
          <isNotEmpty property="input" prepend=",">#input#</isNotEmpty>
          <isNotEmpty property="output" prepend=",">#output#</isNotEmpty>
          <isNotEmpty property="deltaind" prepend=",">#deltaind#</isNotEmpty>
          <isNotEmpty property="description" prepend=",">#description#</isNotEmpty>
          )
          <selectKey resultClass="int" keyProperty="systemruleno">SELECT IDENT_CURRENT('systemrule') as last_insert_id</selectKey>
     </insert>
     <select id="updateFindByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select systemruleno, name, expression, event, input, output, deltaind, description, structureno from systemrule where systemruleno = #systemruleno# and structureno = #structureno#</select>
     <update id="update" parameterClass="java.util.HashMap">
          update systemrule set
          <dynamic prepend=" ">
               <isNotEmpty property="name" prepend=",">name = #name#</isNotEmpty>
               <isEmpty property="name" prepend=",">name = null</isEmpty>
               <isNotEmpty property="expression" prepend=",">expression = #expression#</isNotEmpty>
               <isEmpty property="expression" prepend=",">expression = null</isEmpty>
               <isNotEmpty property="event" prepend=",">event = #event#</isNotEmpty>
               <isEmpty property="event" prepend=",">event = null</isEmpty>
               <isNotEmpty property="input" prepend=",">input = #input#</isNotEmpty>
               <isEmpty property="input" prepend=",">input = null</isEmpty>
               <isNotEmpty property="output" prepend=",">output = #output#</isNotEmpty>
               <isEmpty property="output" prepend=",">output = null</isEmpty>
               <isNotEmpty property="deltaind" prepend=",">deltaind = #deltaind#</isNotEmpty>
               <isEmpty property="deltaind" prepend=",">deltaind = null</isEmpty>
               <isNotEmpty property="description" prepend=",">description = #description#</isNotEmpty>
               <isEmpty property="description" prepend=",">description = null</isEmpty>
          </dynamic>
          where systemruleno = #systemruleno# and structureno = #structureno#
     </update>
     <delete id="delete" parameterClass="java.util.HashMap">delete from systemrule where systemruleno = #systemruleno# and structureno = #structureno#</delete>
     <delete id="deleteAll" parameterClass="java.util.HashMap">delete from systemrule</delete>
     <delete id="deleteAllByPartialKey" parameterClass="java.util.HashMap">delete from systemrule where structureno = #structureno#</delete>
     <select id="findByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select systemruleno, name, expression, event, input, output, deltaind, description, structureno from systemrule where systemruleno = #systemruleno# and structureno = #structureno#</select>
     <select id="search" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select systemruleno, structureno, name, expression, event, input, output from systemrule where structureno = #structureno#</select>
</sqlMap>

