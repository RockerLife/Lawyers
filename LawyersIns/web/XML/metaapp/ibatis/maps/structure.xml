<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="structure">
     <select id="findAll" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from structure</select>
     <select id="findAllByPartialKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select  *  from structure</select>
     <insert id="insert" parameterClass="java.util.HashMap">
          insert into structure(
          <dynamic prepend=" ">
               <isNotEmpty property="project" prepend=",">project</isNotEmpty>
               <isNotEmpty property="version" prepend=",">version</isNotEmpty>
               <isNotEmpty property="seq" prepend=",">seq</isNotEmpty>
          </dynamic>
          ) values (
          <dynamic prepend=" ">
               <isNotEmpty property="project" prepend=",">#project#</isNotEmpty>
               <isNotEmpty property="version" prepend=",">#version#</isNotEmpty>
               <isNotEmpty property="seq" prepend=",">#seq#</isNotEmpty>
          </dynamic>
          )
          <selectKey resultClass="int" keyProperty="structureno">SELECT IDENT_CURRENT('structure') as last_insert_id</selectKey>
     </insert>
     <select id="updateFindByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select structureno, project, version, seq from structure where structureno = #structureno#</select>
     <update id="update" parameterClass="java.util.HashMap">
          update structure set
          <dynamic prepend=" ">
               <isNotEmpty property="project" prepend=",">project = #project#</isNotEmpty>
               <isEmpty property="project" prepend=",">project = null</isEmpty>
               <isNotEmpty property="version" prepend=",">version = #version#</isNotEmpty>
               <isEmpty property="version" prepend=",">version = null</isEmpty>
               <isNotEmpty property="seq" prepend=",">seq = #seq#</isNotEmpty>
               <isEmpty property="seq" prepend=",">seq = null</isEmpty>
          </dynamic>
          where structureno = #structureno#
     </update>
     <delete id="delete" parameterClass="java.util.HashMap">delete from structure where structureno = #structureno#</delete>
     <delete id="deleteAll" parameterClass="java.util.HashMap">delete from structure</delete>
     <delete id="deleteAllByPartialKey" parameterClass="java.util.HashMap">delete from structure</delete>
     <select id="findByKey" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">select structureno, project, version, seq from structure where structureno = #structureno#</select>
     <select id="search" parameterClass="java.util.HashMap" resultClass="java.util.HashMap">
          select structureno, project, version, seq from structure
          <dynamic prepend=" where ">
               <isNotEmpty property="project">project like #project# + '%'</isNotEmpty>
          </dynamic>
     </select>
</sqlMap>

