<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
 
  <xsl:template match="/" name="LPL-AMEND-SC">
     	   <fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		  </fo:block>

          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="5mm" space-after="5mm" font-weight="bold">

            SOUTH CAROLINA AMENDATORY ENDORSEMENT


          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>
                <fo:list-item space-after="4mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                      Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
                    </fo:block>

                    <fo:block>

                      <fo:list-block>
                        <fo:list-item>
                          <fo:list-item-label>
                            <fo:block start-indent="7mm">
                              <fo:inline font-weight="bold">D.</fo:inline>
                            </fo:block>
                          </fo:list-item-label>
                          <fo:list-item-body start-indent="14mm">

                            <fo:block space-after="3mm">
                              <fo:inline font-weight="bold">
                                Cancellation, Nonrenewal and Renewal
                              </fo:inline>
                            </fo:block>
                            <fo:block>
                              <fo:list-block space-after="3mm">

                                <fo:list-item>
                                  <fo:list-item-label start-indent="14mm">
                                    <fo:block>
                                      <fo:inline font-weight="bold">1.</fo:inline>
                                    </fo:block>
                                  </fo:list-item-label>
                                  <fo:list-item-body start-indent="21mm">
                                    <fo:block space-after="3mm">
                                      <fo:inline font-weight="bold">Cancellation</fo:inline>
                                    </fo:block>

                                    <fo:block>

                                      <fo:list-block>

                                        <fo:list-item space-after="3mm">
                                          <fo:list-item-label start-indent="21mm">
                                            <fo:block>
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body start-indent="28mm">
                                            <fo:block>
                                             
                                              The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the expiration date of the 
                                              <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written 
                                              notice to the <fo:inline font-weight="bold">Insurer</fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline>
                                              or its authorized agent.  If the <fo:inline font-weight="bold">Named Insured</fo:inline> cancels this policy, the <fo:inline font-weight="bold">
                                                Insurer</fo:inline> shall return 90% of the unearned portion of the premium.

                                            </fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item space-after="3mm">
                                          <fo:list-item-label start-indent="21mm">
                                            <fo:block>
                                              <fo:inline>(b)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body start-indent="28mm">
                                            
                                            <fo:block>
												The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium
												or Deductible. This policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or
												delivering to the <fo:inline font-weight="bold">Named Insured</fo:inline> and the agent of record, if any, at
												their addresses shown in the policy or, if not reflected therein, at
												their last known addresses, written notice of cancellation not less
												than 10 days prior to the proposed effective date of cancellation. Such
												notice shall state the precise reason for cancellation. Proof of
												mailing is sufficient proof of notice and the effective date of
												cancellation stated in such notice shall become the expiration date of
												the <fo:inline font-weight="bold">Policy Period</fo:inline>. If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline>
												shall credit the <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of the
												premium. Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline> shall
												not be a condition precedent to the effectiveness of cancellation, but
												such payment shall be made as soon as practicable.
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                            
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>

                                    </fo:block>

                                  </fo:list-item-body>
                                </fo:list-item>

                                <fo:list-item>
                                  <fo:list-item-label start-indent="14mm">
                                    <fo:block>
                                      <fo:inline font-weight="bold">2.</fo:inline>
                                    </fo:block>
                                  </fo:list-item-label>
                                  <fo:list-item-body start-indent="21mm">
                                    <fo:block space-after="3mm">
                                      <fo:inline font-weight="bold">Nonrenewal</fo:inline>
                                    </fo:block>

                                    <fo:block start-indent="21mm" space-after="3mm">
									This policy may be nonrenewed by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or delivering
									to the <fo:inline font-weight="bold">Named Insured</fo:inline> and the agent of record, if any, at their
									addresses shown in the policy or, if not reflected therein, at their
									last known addresses, written notice of nonrenewal not less than:
                                    </fo:block>

                                  </fo:list-item-body>
                                </fo:list-item>

                                

                              </fo:list-block>
                            </fo:block>

                            <fo:block>
							  <fo:block>
                              <fo:list-block>
                              <fo:list-item>
                              <fo:list-item-label>
                              <fo:block start-indent="21mm">(a)</fo:block>
                              </fo:list-item-label>
                              <fo:list-item-body>
                              <fo:block start-indent="28mm">60 days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline> for any nonrenewal that would be effective between November first and May thirty-first; and</fo:block>
                              </fo:list-item-body>
                              </fo:list-item>
                              </fo:list-block>
                            </fo:block>
                              
                              
                               <fo:block space-after="3mm">
                              <fo:list-block>
                              <fo:list-item>
                              <fo:list-item-label>
                              <fo:block start-indent="21mm">(b)</fo:block>
                              </fo:list-item-label>
                              <fo:list-item-body>
                              <fo:block start-indent="28mm" >90 days prior to the expiration date of the Policy Period for any nonrenewal that would be effective between June first and October thirty-first.</fo:block>
                              </fo:list-item-body>
                              </fo:list-item>
                              </fo:list-block>
                            </fo:block>
                              <fo:block space-after="3mm" start-indent="21mm">
                                Proof of mailing is sufficient proof of notice.  Such notice shall state the precise reason for nonrenewal.
                              </fo:block>
                           
                            </fo:block>
                            
                            
                            <fo:block space-after="3mm">
                            <fo:list-block>
                              <fo:list-item>
                                  <fo:list-item-label start-indent="14mm">
                                    <fo:block>
                                      <fo:inline font-weight="bold">3.</fo:inline>
                                    </fo:block>
                                  </fo:list-item-label>
                                  <fo:list-item-body start-indent="21mm">
                                    <fo:block space-after="3mm">
                                      <fo:inline font-weight="bold">Renewal</fo:inline>
                                    </fo:block>

                                    <fo:block space-after="3mm" start-indent="21mm">
										If the <fo:inline font-weight="bold">Insurer</fo:inline> intends to renew this policy, it shall furnish renewal
										terms and a statement of the amount of premium or estimated premium due
										for the renewal policy period to the <fo:inline font-weight="bold">Named Insured</fo:inline> not less than 30
										days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.
                                    </fo:block>

   									<fo:block  start-indent="21mm">
   									The <fo:inline font-weight="bold">Insurer</fo:inline> may satisfy its obligation to furnish renewal terms and statement of premium or estimated premium due by either of the following methods:
   									</fo:block>
   									
                                  </fo:list-item-body>
                                
                                
                                </fo:list-item>
                                 </fo:list-block>
                            </fo:block>
                            <fo:block>
                            <fo:list-block>
                                <fo:list-item>
   									<fo:list-item-label>
   									<fo:block start-indent="21mm">
   									<fo:inline >(a)</fo:inline>
   									</fo:block>
   									</fo:list-item-label>
   									<fo:list-item-body>
   									<fo:block start-indent="28mm">
										mailing or delivering renewal terms and statement to the <fo:inline font-weight="bold">Named Insured</fo:inline>
										at its address shown in the policy or, if not reflected therein, at its
										last known address, not less than 30 days prior to the expiration date
										of the <fo:inline font-weight="bold">Policy Period</fo:inline>; or
   									</fo:block>
   									</fo:list-item-body>
   									</fo:list-item>
   									
   									
   									<fo:list-item>
   									<fo:list-item-label>
   									<fo:block start-indent="21mm">
   									<fo:inline >(b)</fo:inline>
   									</fo:block>
   									</fo:list-item-label>
   									<fo:list-item-body>
   									<fo:block start-indent="28mm" space-after="1cm" >
										mailing or delivering renewal terms and statement to the agent of
										record, if any, not less than 45 days prior to the expiration date of
										the <fo:inline font-weight="bold">Policy Period</fo:inline>, along with instructions that the agent furnish the
										renewal terms and statement to the <fo:inline font-weight="bold">Named Insured</fo:inline> not less than 30 days
										prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.
   									</fo:block>
   									
   									 
   									</fo:list-item-body>
   									</fo:list-item>
   									</fo:list-block>
                              </fo:block>
   									</fo:list-item-body>
                        </fo:list-item>
                      </fo:list-block>
                    </fo:block>

                  </fo:list-item-body>
                </fo:list-item>
               </fo:list-block>
   									<fo:block  start-indent="0mm" margin-top="0.5cm" font-size="10px" color="grey" text-align="left">LPL-AMEND-SC (04/17) &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Page 1 of 2</fo:block>
                          
         			  

            </fo:block>
               <fo:block break-after="page" />
          			
       				<fo:block>
						<fo:list-block>
						<fo:list-item>
						<fo:list-item-label>
						<fo:block></fo:block>
						</fo:list-item-label>
						<fo:list-item-body>
						<fo:block start-indent="21mm" margin-top="5mm">
					If the <fo:inline font-weight="bold">Insurer</fo:inline> fails to furnish the renewal terms and statement of
					premium or estimated premium due in the manner required by this
					subsection, the <fo:inline font-weight="bold">Named Insured</fo:inline> may elect to cancel the renewal policy
					within the 30-day period following receipt of the renewal terms and
					statement of premium or estimated premium due. Earned premium for any
					period of coverage must be calculated pro rata based upon the premium
					applicable to the original policy and not the premium applicable to the
					renewal policy.
							</fo:block>
						</fo:list-item-body>
						</fo:list-item>
						 </fo:list-block>
                       </fo:block>
            

            <fo:block margin-top="1cm">
              All other terms, conditions and limitations of the policy remain unaltered.
            </fo:block>

          </fo:block>
           <fo:block margin-top="22cm"/>
           <fo:block  start-indent="0mm" font-size="10px" color="grey" text-align="left">LPL-AMEND-SC (04/17) &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
           &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Page 2 of 2</fo:block>
                          
         
  </xsl:template>
  
</xsl:stylesheet>
