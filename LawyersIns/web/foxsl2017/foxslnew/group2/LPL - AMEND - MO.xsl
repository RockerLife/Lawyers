            MISSOURI AMENDATORY ENDORSEMENT
          </fo:block>
         
          <fo:block margin-top="4mm"></fo:block>
         <!--  <fo:block font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-weight="bold" text-align="center" space-after="4mm">
