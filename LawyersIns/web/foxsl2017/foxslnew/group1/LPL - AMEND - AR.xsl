<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
  <!-- <xsl:output method="xml" indent="no" /> -->
  <xsl:template match="/" name="LPL-AMEND-AR">
    
		<fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		</fo:block>
          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="4mm" space-after="4mm"  font-weight="bold">

            ARKANSAS AMENDATORY ENDORSEMENT


          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="4mm">
              In consideration of the premium charged, it is agreed that:
            </fo:block>

            <fo:block space-after="4mm">

              <fo:list-block>

                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section II., Limits of Liability and Deductible, subsection A., Limits of Liability, is amended as follows:
                      </fo:block>
                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>a.</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                               Paragraphs 1. and 2. are amended by deleting the phrase “including any applicable Extended Reporting Period” and replacing it with “including the Automatic Extended Reporting Period”.
                              </fo:block>
                              <fo:block margin-top="3mm"></fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>b.	</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>
                            

                              <fo:block start-indent="14mm" space-after="3mm">
                                Paragraph 5. is deleted and replaced with the following:
                              </fo:block>

                              <fo:block space-after="3mm">
                                <fo:list-block>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline>5. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>

                                     
                                      <fo:block start-indent="21mm" >
                                        The Limit of Liability in the <fo:inline font-weight="bold">Policy Aggregate</fo:inline> for the Optional Extended Reporting Period and the 
                                        Non-Practicing Extended Reporting Period combined, regardless of the number of Non-Practicing Extended Reporting Periods purchased, 
                                        shall be no less than the greater of the amount of coverage remaining in the expiring <fo:inline font-weight="bold">Policy Aggregate</fo:inline>
                                        or 50% of the <fo:inline font-weight="bold">Policy Aggregate</fo:inline> at inception.
                                      </fo:block>
                                       <fo:block margin-top="3mm"/>
                                    </fo:list-item-body>
                                  </fo:list-item>
                                </fo:list-block>
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                        </fo:list-block>
                      </fo:block>

                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>

                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>2.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm" >
                      <fo:block  space-after="3mm">
                        Section III., Extension of Coverage D., Extended Reporting Period Extensions, is amended as follows:
                      </fo:block>
                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>a.</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                Subsection 1., Automatic Extended Reporting Period, is amended by deletion of the phrase “other than for cancellation for nonpayment of premium or for nonpayment of Deductible due hereunder”.
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>b.	</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                Subsection 2., Optional Extended Reporting, is deleted and replaced with the following:
                              </fo:block>

                              <fo:block>
                                <fo:list-block>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">2.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>

                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold"> Optional Extended Reporting Period </fo:inline>
                                      </fo:block>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        Upon the expiration or cancellation of this policy for any reason, the <fo:inline font-weight="bold">Named Insured</fo:inline> shall have the right,
                                        upon payment of the additional premium shown in one of the options below for the length of time shown, commencing on the expiration date 
                                        of the Automatic Extended Reporting Period, to report <fo:inline font-weight="bold">Claims</fo:inline> pursuant to Section VI., General 
                                        Condition A., Notice of <fo:inline font-weight="bold">Claim</fo:inline> or Circumstance, paragraph 1.
                                      </fo:block>
                                      <fo:block start-indent="21mm">

                                        The Optional Extended Reporting Periods are:
                                        
                                      </fo:block>
                                      <fo:block space-after="3mm">
                                        <fo:list-block>
                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(a)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                12 months for a premium charge of 100% of the annual policy premium;
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(b)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                36 months for a premium charge of 185% of the annual policy premium;
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(c)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                60 months for a premium charge of 225% of the annual policy premium;
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(d)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                	72 months for a premium charge of 250% of the annual policy premium;
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(e)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                	An unlimited period for a premium charge of 300% of the annual policy premium.
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>
                                        </fo:list-block>
                                      </fo:block>

                                      <fo:block start-indent="21mm" space-after="3mm">
                                        
                                        Coverage under such extension of time to report a <fo:inline font-weight="bold">Claim</fo:inline> (referred to below as the Optional 
                                        Extended Reporting Period) shall apply solely to negligent acts, errors or omissions in rendering <fo:inline font-weight="bold">
                                        Professional Services</fo:inline> committed or attempted prior to the effective date of nonrenewal or cancellation, whichever occurs first, and which are not otherwise excluded by any terms, conditions or exclusions of this policy.
                                      </fo:block>
                                      <fo:block start-indent="21mm">

                                        If the Optional Extended Reporting Period requested by the <fo:inline font-weight="bold">Named Insured</fo:inline> is issued by the <fo:inline font-weight="bold">Insurer</fo:inline>:

                                      </fo:block>
                                      <fo:block space-after="3mm">
                                        <fo:list-block>
                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(1)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                	the additional premium shall be fully earned by the <fo:inline font-weight="bold">Insurer</fo:inline>; and
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>
                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(2)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                the Optional Extended Reporting Period cannot be cancelled by the <fo:inline font-weight="bold">Insureds</fo:inline> or the 
                                                <fo:inline font-weight="bold">Insurer</fo:inline>.
                                              </fo:block>
                                            <fo:block margin-top="3mm"/>
                                            </fo:list-item-body>
                                          </fo:list-item>
                                          
                                        </fo:list-block>
                                      </fo:block>
                                      
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  
                                </fo:list-block>
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>c. </fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                Subsection 3., Non-Practicing Extended Reporting Period, subsection (c), Non-Practicing Extended Reporting Period Limits of Liability, is amended by deletion of the first paragraph.
                              </fo:block>
                              <fo:block break-after="page"/>
                            </fo:list-item-body>
                          </fo:list-item>

                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>d.	</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                Subsection 4., Conditions for Extended Reporting Periods, is deleted and replaced with the following:
                              </fo:block>

                              <fo:block>
                                <fo:list-block>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">4.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>

                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold"> Conditions for Extended Reporting Periods </fo:inline>
                                      </fo:block>
                                      
                                      <fo:block start-indent="21mm">

                                        As a condition precedent to the right to elect an Extended Reporting Period:

                                      </fo:block>
                                      <fo:block space-after="3mm">
                                        <fo:list-block>
                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(a)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                all <fo:inline font-weight="bold">Insureds</fo:inline> must be in compliance with the terms and conditions of the policy;
                                              </fo:block>

                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(b)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                the <fo:inline font-weight="bold">Named Insured’s</fo:inline> right to practice law has not been revoked, suspended or surrendered at the request of any regulatory authority for reasons other than death, disability or retirement; and
                                              </fo:block>
                                              <fo:block margin-top="6mm"/>
         							  <fo:block start-indent="2mm" font-size="10px" color="grey" text-align="left">LPL-AMEND-AR (04/17)</fo:block>
         

                                            </fo:list-item-body>
                                          </fo:list-item>

                                          <fo:list-item>
                                            <fo:list-item-label>
                                              <fo:block start-indent="21mm">
                                                <fo:inline>(c)	</fo:inline>
                                              </fo:block>
                                            </fo:list-item-label>
                                            <fo:list-item-body>

                                              <fo:block start-indent="28mm">
                                                the <fo:inline font-weight="bold">Named Insured</fo:inline> provides the <fo:inline font-weight="bold">Insurer</fo:inline>
                                                with written notice of its selection and pays the premium charge, and any other monies due and owing the <fo:inline font-weight="bold">Insurer</fo:inline>, 
                                                if applicable, for the selected Extended Reporting Period in full within 60 days of the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.
                                              </fo:block>
												
         							
                                            </fo:list-item-body>
                                          </fo:list-item>

                                        </fo:list-block>
                                      </fo:block>

                                      <fo:block start-indent="21mm" space-after="3mm">
                                          
                                          This right to elect an Extended Reporting Period shall lapse unless the provisions of (a) through (c) in the preceding paragraph are fully met.
                                          
                                      </fo:block>
                                     <fo:block margin-top="3mm"></fo:block>
                                    </fo:list-item-body>
                                  </fo:list-item>

                                </fo:list-block>
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>
                        </fo:list-block>
                      </fo:block>

                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>

                <fo:list-item>
                  <fo:list-item-label>
                
                    <fo:block>
                      <fo:inline>3. </fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block space-after="3mm" start-indent="7mm">
                      <fo:block>
                        Section IV., Definition N., <fo:inline font-weight="bold">Policy Aggregate</fo:inline>, is amended by deleting the phrase “inclusive of any applicable Extended Reporting Period” and replacing it with “inclusive of the Automatic Extended Reporting Period”.
                      </fo:block>

                    </fo:block>
                    
                      <fo:block margin-top="3mm"></fo:block>
                     
                  
                    
                  </fo:list-item-body>
                </fo:list-item>
                    
                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>4.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section IV., Definition Q., <fo:inline font-weight="bold">Prior Acts Date</fo:inline>, is amended by addition of the following:
                      </fo:block>
                      
                      <fo:block>
                        The <fo:inline font-weight="bold">Prior Acts Date</fo:inline> may only be advanced with the written consent of the <fo:inline font-weight="bold">Named Insured</fo:inline> and upon one or more of the following conditions:
                      </fo:block>
                      <fo:block>   
                       

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>1. </fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm">
                                there is a change in Insurer other than an insurer within the same insurance holding company or group;
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>2.	</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm">
                                there is a substantial change in the <fo:inline font-weight="bold">Insured’s</fo:inline> operations which would have been a material factor in
                                the <fo:inline font-weight="bold">Insurer’s</fo:inline> acceptance or declination of the risk; or
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline>3.	</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm">
                                at the request of the <fo:inline font-weight="bold">Named Insured</fo:inline>.
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>
                          
                        </fo:list-block>
                      </fo:block>
                      <fo:block start-indent="7mm" space-after="3mm">
                        Prior to advancement of the <fo:inline font-weight="bold">Prior Acts Date</fo:inline>, the <fo:inline font-weight="bold">Named Insured</fo:inline> must receive a disclosure form for its signature which acknowledges that it has been advised of its right to purchase an Optional Extended Reporting Period.
                      </fo:block>
                      
                    </fo:block>
                    <fo:block margin-top="3mm"></fo:block>
                  </fo:list-item-body>
                </fo:list-item>

                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>5. </fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block space-after="3mm" start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section VI., General Condition A., Notice of <fo:inline font-weight="bold">Claim</fo:inline> or Circumstance, is amended by addition of the following:
                      </fo:block>

                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline font-weight="bold">•</fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>
 						
                              <fo:block start-indent="11mm">
                                 Notice of <fo:inline font-weight="bold">Claim</fo:inline> given by or on behalf of the <fo:inline font-weight="bold">Named Insured</fo:inline>
                                to any authorized agent of the <fo:inline font-weight="bold">Insurer</fo:inline> with specific information to identify the <fo:inline font-weight="bold">
                                  Insured</fo:inline> is deemed notice of <fo:inline font-weight="bold">Claim</fo:inline> to the <fo:inline font-weight="bold">Insurer</fo:inline>.
                              </fo:block>
                            </fo:list-item-body>
                          </fo:list-item>
                        </fo:list-block>
                      </fo:block>
                      
                    </fo:block>
                    <fo:block margin-top="3mm"></fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>6.	</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section VI., General Condition D., Cancellation and Nonrenewal, is deleted and replaced with the following:
                      </fo:block>
                      <fo:block>

                        <fo:list-block>
                          <fo:list-item>
                            <fo:list-item-label>
                              <fo:block start-indent="7mm">
                                <fo:inline font-weight="bold">D. </fo:inline>
                              </fo:block>
                            </fo:list-item-label>
                            <fo:list-item-body>

                              <fo:block start-indent="14mm" space-after="3mm">
                                <fo:inline font-weight="bold"> Cancellation, Nonrenewal and Conditional Renewal</fo:inline>
                              </fo:block>
                              <fo:block>
                                <fo:list-block>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">1.</fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Cancellation</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              The <fo:inline font-weight="bold">Named Insured</fo:inline> may cancel this policy at any time prior to the expiration date of the
                                              <fo:inline font-weight="bold">Policy Period</fo:inline> by providing prior written notice to the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> or by surrender of this policy to the <fo:inline font-weight="bold">Insurer</fo:inline> or its authorized
                                              agent.  If the <fo:inline font-weight="bold">Named Insured</fo:inline> cancels this policy, the <fo:inline font-weight="bold">
                                                Insurer
                                              </fo:inline> shall return 90% of the unearned portion of the premium.
                                            </fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(b)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              <fo:block space-after="3mm">
                                                
                                                The <fo:inline font-weight="bold">Insurer</fo:inline> may only cancel this policy for nonpayment of premium.  This
                                                policy may be canceled by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or delivering to the <fo:inline font-weight="bold">
                                                  Named Insured
                                                </fo:inline>, at its last known address, written notice of cancellation at least 10 days
                                                before the effective date of cancellation. Such notice shall be accompanied by the reason for cancellation.  The mailing of such notice shall be sufficient
                                                proof of notice and the effective date of cancellation stated in such notice shall become the expiration date of the <fo:inline font-weight="bold">Policy
                                                Period.</fo:inline>  If the <fo:inline font-weight="bold">Insurer</fo:inline> cancels this policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall credit the
                                                <fo:inline font-weight="bold">Named Insured</fo:inline> the pro rata unearned portion of the
                                                premium.  Payment or tender of any unearned premium by the <fo:inline font-weight="bold">Insurer</fo:inline> shall not be a condition precedent to the effectiveness of
                                                cancellation, but such payment shall be made as soon as practicable.

                                              </fo:block>
                                            
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">2. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Nonrenewal</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm" space-after="3mm">
                                             
                                              This policy may be nonrenewed by the <fo:inline font-weight="bold">Insurer</fo:inline> by mailing or delivering to the
                                              <fo:inline font-weight="bold">Named Insured</fo:inline>, at its last known address, written notice of nonrenewal at least 60 days 
                                              prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>.  The mailing of such notice shall be 
                                              sufficient proof of notice.  Notice of nonrenewal is not required in the case of nonpayment of premium.
                                              
                                            </fo:block>
                                            <fo:block break-after="page"/>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(b) </fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              <fo:block space-after="3mm">

                                                If the notice is not given as stated in paragraph 2(a) above, the <fo:inline font-weight="bold">Insurer</fo:inline>
                                                must remain on the risk for an additional 12 months at substantially the same policy conditions and rates.  Realistic rate adjustments for market conditions and changes in the risk are acceptable.
                                                
                                              </fo:block>
                                              
                                            </fo:block>
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>

                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">3. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Conditional Renewal</fo:inline>
                                      </fo:block>
                                      <fo:list-block space-after="3mm">
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">

                                              If the <fo:inline font-weight="bold">Insurer</fo:inline> revises its rates or rules and the revision results in a premium 
                                              increase equal to or greater than 25% on the renewal policy, the <fo:inline font-weight="bold">Insurer</fo:inline> shall mail or
                                              deliver to the <fo:inline font-weight="bold">Named Insured’s</fo:inline> agent not less than 60 days prior to the expiration date 
                                              of the <fo:inline font-weight="bold">Policy Period</fo:inline>, and to the <fo:inline font-weight="bold">Named Insured</fo:inline>
                                              at its last known address not less than 30 days prior to the expiration date of the <fo:inline font-weight="bold">Policy Period</fo:inline>
                                              , written notice specifically stating the <fo:inline font-weight="bold">Insurer’s</fo:inline> intention to increase the premium by such amount.
                                              
                                            </fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(b) </fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              <fo:block>

                                                If the notice is not given as stated in paragraph 3(a) above, the <fo:inline font-weight="bold">Insurer</fo:inline> is required
                                                to extend the existing policy 60 days from the date the notice is mailed or delivered.  The premium for the policy as extended in such circumstances shall be no more than the pro rata premium of the existing policy.
                                              
                                              </fo:block>

                                            </fo:block>
                                             <fo:block margin-top="6mm"/>
                                            <fo:block start-indent="2mm"  font-size="10px" color="grey" text-align="left">LPL-AMEND-AR (04/17)</fo:block>
                                              <fo:block margin-top="0.5cm"/>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>
                                  
                                  
                                  
                                  
                                  

                                  <fo:list-item>
                                    <fo:list-item-label>
                                      <fo:block start-indent="14mm">
                                        <fo:inline font-weight="bold">4. </fo:inline>
                                      </fo:block>
                                    </fo:list-item-label>
                                    <fo:list-item-body>
                                      <fo:block start-indent="21mm" space-after="3mm">
                                        <fo:inline font-weight="bold">Claims-Made Requirements</fo:inline>
                                      </fo:block>
                                      <fo:list-block>
                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(a)</fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm">
                                              
                                              Any notice of cancellation or nonrenewal shall include a disclosure advising the <fo:inline font-weight="bold">Named Insured</fo:inline> and its agent of the availability of and premium for the Optional Extended Reporting Period and the importance of purchasing the coverage.
                                            
                                            </fo:block>
                                            
                                          
                                          </fo:list-item-body>
                                       
                                          
                                        </fo:list-item>

                                        <fo:list-item>
                                          <fo:list-item-label>
                                            <fo:block start-indent="21mm">
                                              <fo:inline>(b) </fo:inline>
                                            </fo:block>
                                          </fo:list-item-label>
                                          <fo:list-item-body>
                                            <fo:block start-indent="28mm" space-after="3mm">
                                              
                                                The <fo:inline font-weight="bold">Insurer</fo:inline> shall provide the following loss information to the <fo:inline font-weight="bold">
                                                  Named Insured</fo:inline> within 30 days of its request and within 15 days after notice of cancellation or nonrenewal is
                                                  issued: (i) description of closed <fo:inline font-weight="bold">Claims</fo:inline> including the date and description of 
                                                  occurrence, amount of payments, if any; (ii) description of open <fo:inline font-weight="bold">Claims</fo:inline> including the date and description of occurrence, amount of payments, if any, and an estimate of reserves, if any; and (iii) information on notices of occurrence including the date and an estimate of reserves, if any.
                                               
                                            </fo:block>
                                            
                                            <fo:block margin-top="3mm"></fo:block>
                                          </fo:list-item-body>
                                        </fo:list-item>

                                      </fo:list-block>
                                    </fo:list-item-body>
                                  </fo:list-item>

                                </fo:list-block>
                              </fo:block>

                            </fo:list-item-body>
                          </fo:list-item>

                        </fo:list-block>
                      </fo:block>

                    </fo:block>
                     
                  </fo:list-item-body>
                </fo:list-item>

             


                <fo:list-item>
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>7. </fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>
                    <fo:block start-indent="7mm">
                      <fo:block space-after="3mm">
                        Section VI., General Condition F., Subrogation, is amended by addition of the following:
                      </fo:block>


                      <fo:block start-indent="7mm" space-after="6mm">
                        The <fo:inline font-weight="bold">Insurer</fo:inline> shall be entitled to recovery only after the  <fo:inline font-weight="bold">Insured</fo:inline>
                        has been fully compensated for the loss sustained.
                      </fo:block>

                    </fo:block>
                  </fo:list-item-body>
                </fo:list-item>
                
              </fo:list-block>

            </fo:block>

            <fo:block margin-top="3mm">
              All other terms, conditions and limitations of the policy remain unaltered.
            </fo:block>
          </fo:block>
        
           <fo:block margin-top="19cm"/>
           <fo:block  font-size="10px" color="grey" text-align="left">LPL-AMEND-AR (04/17)</fo:block>
         
  </xsl:template> 
