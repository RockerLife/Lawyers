<?xml version="1.0" encoding="utf-8"?>
<xsl:stylesheet version="1.1"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	exclude-result-prefixes="fo"
	xmlns:fn="http://www.w3.org/2005/02/xpath-functions"
	xmlns:java="java">
 
  <xsl:template match="/" name="LPL-AMEND-DC">
          <fo:block>				  	
			<xsl:call-template name="CommonHeader" />						           	
		  </fo:block>

          <fo:block text-align="center" margin-left="1.3in" margin-right="1.3in" font-size="12px" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" space-before="5mm" space-after="5mm" font-weight="bold">

            DISTRICT OF COLUMBIA AMENDATORY ENDORSEMENT


          </fo:block>
          <fo:block padding-left="5pt" font-family="Arial, 'Helvetica Neue', Helvetica, sans-serif;" font-size="10px" text-align="justify">

            <fo:block space-after="3mm">
              In consideration of the premium charged, it is agreed that Section VI., General Condition D., Cancellation and Nonrenewal, is amended as follows:
            </fo:block>
           
            <fo:block space-after="3mm">

              <fo:list-block>
                 <fo:list-item space-after="3mm">
                <fo:list-item-label>
                    <fo:block>
                      <fo:inline>1.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                 <fo:list-item-body>

                    <fo:block start-indent="7mm">
                      Paragraph 2. is amended by deleting the phrase “at least 10 days” and replacing it with “at least 30 days”.
                    </fo:block>
                  </fo:list-item-body>
                  </fo:list-item>
                <fo:list-item space-after="3mm">
                  <fo:list-item-label>
                    <fo:block>
                      <fo:inline>2.</fo:inline>
                    </fo:block>
                  </fo:list-item-label>
                  <fo:list-item-body>

                    <fo:block space-after="3mm" start-indent="7mm">
                      The following paragraphs are added:
                    </fo:block>
                    <fo:block>
                      
                      <fo:list-block>
                        <fo:list-item space-after="3mm">
                          <fo:list-item-label>
                            <fo:block start-indent="7mm">
                              <fo:inline font-weight="bold">•</fo:inline>
                            </fo:block>
                          </fo:list-item-label>
                          <fo:list-item-body>

                            <fo:block start-indent="11mm">
                           At least five days before sending the notice of cancellation or nonrenewal, the <fo:inline font-weight="bold">Insurer</fo:inline> shall notify the insurance 
                         agent or broker who wrote the policy being nonrenewed or cancelled.</fo:block>
                          </fo:list-item-body>
                        </fo:list-item>
                      
                    <fo:list-item space-after="3mm">
                          <fo:list-item-label>
                            <fo:block start-indent="7mm">
                             <fo:inline font-weight="bold">•</fo:inline>
                            </fo:block>
                          </fo:list-item-label>
                          <fo:list-item-body>

                            <fo:block start-indent="11mm">
                             The notice of cancellation or nonrenewal shall set forth a reasonable explanation of the ground or grounds relied 
                            upon by the <fo:inline font-weight="bold">Insurer</fo:inline> as the basis of cancellation or nonrenewal. </fo:block>
                          </fo:list-item-body>
                        </fo:list-item>
                      
                      <fo:list-item space-after="3mm">
                          <fo:list-item-label>
                            <fo:block start-indent="7mm">
                              <fo:inline font-weight="bold">•</fo:inline>
                            </fo:block>
                          </fo:list-item-label>
                          <fo:list-item-body>

                            <fo:block start-indent="11mm">
                              Unless the <fo:inline font-weight="bold">Insurer</fo:inline> complies with each of the conditions specified in this section, the 
                              <fo:inline font-weight="bold">Named Insured</fo:inline> has a right to <fo:inline font-weight="bold">Renewal</fo:inline> for an additional 
                              period of time equivalent to the expiring term if the agreed term is a year or less, or for one year if the agreed term is longer than one year.
                              For the purposes of this endorsement, the term “<fo:inline font-weight="bold">Renewal</fo:inline>” means the issuance and delivery of a policy 
                              with comparable terms which replaces, at the end of the <fo:inline font-weight="bold">Policy Period</fo:inline>, a policy previously issued and 
                              delivered by the same <fo:inline font-weight="bold">Insurer</fo:inline> to the same <fo:inline font-weight="bold">Named Insured</fo:inline>.
                            </fo:block>
                       
                          </fo:list-item-body>
                        </fo:list-item>
                          
                      </fo:list-block>
                    </fo:block>

                  </fo:list-item-body>
                </fo:list-item>
                
              </fo:list-block>

            </fo:block>

            <fo:block>
              All other terms, conditions and limitations of the policy remain unaltered.
            </fo:block>

          </fo:block>
           <fo:block margin-top="12cm"/>
           <fo:block  font-size="10px" color="grey" text-align="left">LPL-AMEND-DC (04/17)</fo:block>
         
  </xsl:template>

</xsl:stylesheet>
